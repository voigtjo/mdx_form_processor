<section class="hero-card">
  <div>
    <span class="eyebrow">Konfigurations-UI</span>
    <h2>Workflows</h2>
    <p>Finder fuer sichtbare Workflow Templates mit Detailsprung, lesbarer Statusfolge und dem heutigen Nutzungskontext in Templates und Documents.</p>
  </div>
  <div class="hero-actions">
    <a class="button-primary" href="/workflows/new?user=<%= activeUser.key %>">New Workflow</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Workflows List</h3>
    <p class="panel-copy">Lesbare Konfigurationsliste mit Detailsprung statt Inline-Review unter der Tabelle.</p>
  </div>
  <% if (catalog.workflows.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Workflows sichtbar.</strong>
      <p>Im aktuellen Konfigurationskontext gibt es keine sichtbaren Workflow Templates.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Initial</th>
            <th>Main Flow</th>
            <th>Status</th>
            <th>Version</th>
            <th>Usage</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% catalog.workflows.forEach((workflow) => { %>
            <% const relatedTemplates = catalog.templates.filter((template) => template.workflowTemplateId === workflow.id); %>
            <% const relatedDocuments = catalog.documents.filter((document) => relatedTemplates.some((template) => template.id === document.templateId)); %>
            <% const mainAction = workflow.actions[0]; %>
            <tr>
              <td>
                <strong><a class="text-link" href="/workflows/<%= workflow.id %>?user=<%= activeUser.key %>"><%= workflow.name %></a></strong>
                <p class="table-meta"><%= workflow.key %></p>
                <% if (workflow.description) { %>
                  <p class="table-meta"><%= workflow.description %></p>
                <% } %>
              </td>
              <td><%= workflow.initialStatus %></td>
              <td>
                <strong><%= workflow.statuses.join(" → ") %></strong>
                <% if (mainAction) { %>
                  <p class="table-meta"><%= mainAction.name %>: <%= mainAction.from.join(", ") %> → <%= mainAction.to %></p>
                <% } %>
              </td>
              <td><span class="status-pill status-<%= workflow.status %>"><%= workflow.status %></span></td>
              <td>v<%= workflow.version %></td>
              <td><%= relatedTemplates.length %> Templates · <%= relatedDocuments.length %> Documents</td>
              <td>
                <div class="table-actions">
                  <a class="text-link" href="/workflows/<%= workflow.id %>?user=<%= activeUser.key %>">View</a>
                  <% if (relatedTemplates.length > 0) { %>
                    <a class="text-link" href="/templates/<%= relatedTemplates[0].id %>?user=<%= activeUser.key %>">Open Templates</a>
                  <% } else { %>
                    <span class="table-meta">Keine Templates</span>
                  <% } %>
                  <a class="text-link" href="/documents?user=<%= activeUser.key %>&q=<%= encodeURIComponent(workflow.key) %>">Open Documents</a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
