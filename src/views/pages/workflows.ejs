<section class="hero-card">
  <div>
    <span class="eyebrow">Konfigurations-UI</span>
    <h2>Workflows</h2>
    <p>Lesbare Uebersicht fuer JSON-basierte Workflow-Templates, Actions, Statusfolgen und Hooks.</p>
  </div>
  <div class="hero-actions">
    <button class="button-primary" type="button">New Workflow</button>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Workflows List</h3>
    <p class="panel-copy">Start mit Review-Daten statt Builder-Fokus.</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Key</th>
          <th>Statusfolge</th>
          <th>Status</th>
          <th>Version</th>
        </tr>
      </thead>
      <tbody>
        <% catalog.workflows.forEach((workflow) => { %>
          <tr>
            <td><%= workflow.name %></td>
            <td><%= workflow.key %></td>
            <td><%= workflow.statuses.join(" → ") %></td>
            <td><span class="status-pill status-<%= workflow.status %>"><%= workflow.status %></span></td>
            <td>v<%= workflow.version %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="grid two-up">
  <article class="panel subtle">
    <h3>Overview</h3>
    <ul class="stack-list compact">
      <% catalog.workflows[0].actions.forEach((action) => { %>
        <li>
          <strong><%= action.name %></strong>
          <p><%= action.from.join(", ") %> → <%= action.to %> · Rollen: <%= action.allowedRoles.join(", ") %></p>
        </li>
      <% }) %>
    </ul>
  </article>
  <article class="panel subtle">
    <h3>JSON / Hooks / Usage</h3>
    <p>Die spaeteren Detailtabs sind hier bereits als Struktur vorgesehen, aber bewusst noch nicht voll umgesetzt.</p>
  </article>
</section>

