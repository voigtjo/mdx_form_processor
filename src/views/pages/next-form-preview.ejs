<section class="hero-card">
  <div>
    <span class="eyebrow">Next Form Preview</span>
    <h2><%= nextFormPreview.parsedForm?.meta.title ?? "Next Form Source + Preview" %></h2>
    <p>Isolierter Editor-/Preview-Pfad fuer die neue schlanke Formularsyntax. Eine einzige Formularquelle erzeugt hier die read-only Vorschau, weiterhin ohne Produkt-UI und ohne Laufzeitintegration.</p>
  </div>
  <div class="hero-actions">
    <% if (nextFormPreview.parsedForm) { %>
      <span class="chip">v<%= nextFormPreview.parsedForm.meta.version %></span>
    <% } else { %>
      <span class="chip">Parse Error</span>
    <% } %>
  </div>
</section>

<form method="post" action="/next-form-preview/craftsman-order<%= activeUser.key !== 'preview' ? `?user=${encodeURIComponent(activeUser.key)}` : '' %>" class="form-stack">
  <section class="grid two-up">
    <article class="panel">
      <div class="panel-header">
        <h3>Formularquelle</h3>
        <span class="chip">Single Source of Truth</span>
      </div>
      <p class="field-help">Dateibasis: <code><%= nextFormPreview.sourceFilePath %></code></p>
      <label class="field-label" for="next-form-source">Schlanke Formularsyntax</label>
      <textarea id="next-form-source" name="source" class="next-form-source-editor"><%= nextFormPreview.sourceText %></textarea>
      <div class="filter-actions">
        <button type="submit" class="button-primary" name="intent" value="apply-preview">Apply Preview</button>
        <button type="submit" class="button-secondary" name="intent" value="save-state">Save</button>
        <button type="submit" class="button-secondary" name="intent" value="load-state">Restore Last Saved</button>
        <a class="button-secondary" href="/next-form-preview/craftsman-order<%= activeUser.key !== 'preview' ? `?user=${encodeURIComponent(activeUser.key)}` : '' %>">Reset to File</a>
      </div>
      <% if (nextFormPreview.savedState) { %>
        <p class="field-help">Zuletzt gespeichert: <strong><%= nextFormPreview.savedState.savedAt %></strong></p>
      <% } %>
      <% if (nextFormPreview.parsedForm) { %>
        <p class="field-help">In dieser Formularquelle erkannt: <strong><%= nextFormPreview.parsedForm.actions.length %> Action-/Lookup-Elemente</strong>.</p>
        <% if (nextFormPreview.parsedForm.actions.length > 0) { %>
          <ul class="stack-list compact">
            <% nextFormPreview.parsedForm.actions.forEach((element) => { %>
              <li><strong><%= element.label ?? element.name %></strong> · <%= element.kind === "action" ? "Action" : "Lookup" %></li>
            <% }) %>
          </ul>
        <% } %>
      <% } %>
    </article>

    <article class="panel">
      <h3>Bearbeitungsfluss</h3>
      <p class="panel-copy">Die neue schlanke Syntax ist hier der primaere Bearbeitungsweg. Darunter wird jetzt das Formular selbst zum Nutzungsort: Eingabe, Action und Rueckbindung passieren direkt im Formularfluss.</p>
      <div class="empty-state">
        <strong>Neues Formularmodell</strong>
        <p>Keine Produktintegration und kein Builder. Die Dateiquelle bleibt der Startzustand, der isolierte Formularwertzustand kann jetzt lokal gespeichert und wieder geladen werden.</p>
      </div>
      <% if (nextFormPreview.parsedForm) { %>
        <ul class="stack-list compact">
          <li><strong>Title:</strong> <%= nextFormPreview.parsedForm.meta.title %></li>
          <li><strong>Key:</strong> <%= nextFormPreview.parsedForm.meta.key %></li>
          <li><strong>Version:</strong> <%= nextFormPreview.parsedForm.meta.version %></li>
          <li><strong>Sections:</strong> <%= nextFormPreview.parsedForm.sections.length %></li>
          <li><strong>Fields:</strong> <%= nextFormPreview.parsedForm.controls.length %></li>
          <li><strong>Actions / Lookups:</strong> <%= nextFormPreview.parsedForm.actions.length %></li>
        </ul>
      <% } %>
    </article>
  </section>

<% if (nextFormPreview.parseError) { %>
  <section class="panel">
    <div class="notice-card notice-error">
      <strong>Quelle aktuell nicht lesbar</strong>
      <p><%= nextFormPreview.parseError %></p>
    </div>
  </section>
<% } else if (nextFormPreview.parsedForm) { %>
  <section class="panel">
    <div class="panel-header">
      <h3>Form Preview</h3>
      <span class="chip"><%= nextFormPreview.parsedForm.controls.length %> Felder · <%= nextFormPreview.parsedForm.actions.length %> Actions</span>
    </div>
    <p class="panel-copy">Erster benutzbarer Formularschnitt aus der aktuell bearbeiteten Quelle. Lookup-Eingaben, Lookup-Ergebnisse, editierbare Felder und readonly Felder bleiben hier bewusst klein und direkt sichtbar.</p>

    <% if (nextFormPreview.actionState) { %>
      <div class="notice-card <%= nextFormPreview.actionState.type === 'error' ? 'notice-error' : 'notice-success' %>">
        <strong><%= nextFormPreview.actionState.title %></strong>
        <p><%= nextFormPreview.actionState.message %></p>
      </div>
    <% } %>

    <div class="next-form-readonly-stack">
      <% nextFormPreview.parsedForm.sections.forEach((section) => { %>
        <article class="subpanel next-form-readonly-section">
          <div class="panel-header">
            <h4><%= section.title %></h4>
            <span class="chip"><%= section.rows.length %> Zeilen</span>
          </div>

          <% section.rows.forEach((row) => { %>
            <div class="next-form-readonly-row next-form-columns-<%= Math.min(row.slots.length, 3) %>">
              <% row.slots.forEach((slot) => { %>
                <% const element = slot.element; %>
                <% const optionHint = typeof element.properties.options === "string" ? element.properties.options.split(",").join(", ") : ""; %>
                <% const currentValue = nextFormPreview.fieldValues[element.name] ?? ""; %>
                <% if (element.kind === "field") { %>
                  <article class="field-block next-form-readonly-field next-form-type-<%= element.controlType %>">
                    <div class="next-form-field-head">
                      <label class="field-label"><%= element.label ?? element.name %></label>
                      <% if (element.properties.required === true) { %>
                        <span class="chip">Pflichtfeld</span>
                      <% } %>
                    </div>

                    <% if (element.name === "order_number") { %>
                      <input
                        class="text-input"
                        type="text"
                        name="order_number"
                        value="<%= currentValue %>"
                        placeholder="z. B. O-ca26a72f-1"
                      />
                    <% } else if (element.name === "customer") { %>
                      <input
                        class="text-input"
                        type="text"
                        name="customer"
                        value="<%= currentValue %>"
                        readonly
                      />
                    <% } else if (element.name === "service_location") { %>
                      <textarea
                        class="next-form-runtime-textarea"
                        name="service_location"
                      ><%= currentValue %></textarea>
                    <% } else if (element.controlType === "textarea") { %>
                      <div class="next-form-value next-form-value-textarea"><%= currentValue || "Noch kein Wert" %></div>
                    <% } else if (element.controlType === "select") { %>
                      <div class="next-form-value"><%= currentValue || "Noch keine Auswahl" %></div>
                    <% } else { %>
                      <div class="next-form-value"><%= currentValue || "Noch kein Wert" %></div>
                    <% } %>

                    <% if (element.name === "order_number") { %>
                      <p class="field-help">Aktiver Eingabewert fuer den ersten ERP-SIM-Lookup.</p>
                    <% } else if (element.name === "customer") { %>
                      <p class="field-help">Wird bei erfolgreichem `Kundendaten laden` aus dem ERP-SIM gebunden.</p>
                    <% } else if (element.name === "service_location") { %>
                      <p class="field-help">Kann aus dem Kundenlookup vorbefuellt und danach manuell angepasst werden.</p>
                    <% } else if (element.controlType === "select" && optionHint) { %>
                      <p class="field-help">Auswahl: <%= optionHint %></p>
                    <% } else if (element.controlType === "textarea") { %>
                      <p class="field-help">Mehrzeiliges read-only Feld.</p>
                    <% } else { %>
                      <p class="field-help">Read-only Vorschau fuer <%= element.controlType %>.</p>
                    <% } %>
                  </article>
                <% } else { %>
                  <article class="field-block next-form-readonly-field next-form-action-card next-form-type-<%= element.controlType %>">
                    <div class="next-form-field-head">
                      <label class="field-label"><%= element.label ?? element.name %></label>
                      <span class="chip"><%= element.kind === "action" ? "Action" : "Lookup" %></span>
                    </div>
                    <% if (element.name === "load_customer") { %>
                      <button type="submit" class="next-form-action-button next-form-action-submit" name="intent" value="run-action"><%= element.label ?? element.name %></button>
                      <input type="hidden" name="actionName" value="load_customer" />
                    <% } else { %>
                      <div class="next-form-action-button" aria-disabled="true"><%= element.label ?? element.name %></div>
                    <% } %>
                    <div class="next-form-action-meta">
                      <% if (element.ref) { %>
                        <p><strong>Ref:</strong> <code><%= element.ref %></code></p>
                      <% } %>
                      <% if (element.args && element.args.length > 0) { %>
                        <p><strong>Args:</strong> <%= element.args.join(", ") %></p>
                      <% } %>
                      <% if (element.bind && element.bind.length > 0) { %>
                        <p><strong>Bind:</strong> <%= element.bind.join(", ") %></p>
                      <% } %>
                      <% if (element.name !== "load_customer") { %>
                        <p><strong>Status:</strong> Noch nicht aktiv in diesem Slice.</p>
                      <% } %>
                    </div>
                  </article>
                <% } %>
              <% }) %>
            </div>
          <% }) %>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>
</form>

<section class="panel">
  <h3>Review</h3>
  <p class="panel-copy">Nachrangige technische Sicht fuer Parse-Struktur und Slot-Aufteilung derselben Formularquelle.</p>

  <% if (nextFormPreview.parsedForm) { %>
    <details class="next-form-review-block">
      <summary>Sections / Rows / Slots</summary>
      <div class="stack-list">
        <% nextFormPreview.parsedForm.sections.forEach((section, sectionIndex) => { %>
          <article class="subpanel next-form-section">
            <div class="panel-header">
              <h4><%= section.title %></h4>
              <span class="chip">Section <%= sectionIndex + 1 %></span>
            </div>
            <% section.rows.forEach((row, rowIndex) => { %>
              <div class="next-form-row-block">
                <p class="next-form-row-label"><strong>Row <%= rowIndex + 1 %></strong> · <%= row.slots.length %> Slots</p>
                <div class="next-form-slot-grid">
                  <% row.slots.forEach((slot, slotIndex) => { %>
                    <article class="subpanel next-form-slot">
                      <p class="next-form-slot-title"><strong>Slot <%= slotIndex + 1 %></strong></p>
                      <p><strong>Kind:</strong> <%= slot.element.kind %></p>
                      <p><strong>Type:</strong> <%= slot.element.controlType %></p>
                      <p><strong>Name:</strong> <%= slot.element.name %></p>
                      <p><strong>Label:</strong> <%= slot.element.label ?? "ohne Label" %></p>
                      <p><strong>Source:</strong> <code><%= slot.source %></code></p>
                      <% if (slot.element.ref) { %>
                        <p><strong>Ref:</strong> <code><%= slot.element.ref %></code></p>
                      <% } %>
                      <div class="next-form-properties">
                        <strong>Properties</strong>
                        <ul class="stack-list compact">
                          <% Object.entries(slot.element.properties).forEach(([key, value]) => { %>
                            <li><code><%= key %></code>: <%= String(value) %></li>
                          <% }) %>
                        </ul>
                      </div>
                    </article>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </article>
        <% }) %>
      </div>
    </details>
  <% } %>
</section>
