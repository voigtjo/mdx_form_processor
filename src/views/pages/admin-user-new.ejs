<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2>New User</h2>
    <p>Kleiner erster Pflegepfad fuer einen auswaehlbaren MVP-User ohne Auth- oder Identity-Architektur.</p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/admin?user=<%= activeUser.key %>">Back to Admin</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Create User</h3>
    <p class="panel-copy">Im ersten Schnitt werden nur die fuer den MVP noetigen Basisfelder angelegt.</p>
  </div>
  <form method="post" action="/admin/users/new?user=<%= activeUser.key %>" class="form-stack">
    <div class="field-block">
      <label class="field-label" for="user-display-name">Display Name</label>
      <input id="user-display-name" name="displayName" type="text" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="user-key">Key</label>
      <input id="user-key" name="key" type="text" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="user-email">E-Mail</label>
      <input id="user-email" name="email" type="text" />
    </div>
    <button class="button-primary" type="submit">Create User</button>
  </form>
</section>
