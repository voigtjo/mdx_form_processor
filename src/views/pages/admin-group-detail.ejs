<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2><%= adminGroupDetail.group.name %></h2>
    <p>Kleine Einzelansicht fuer eine verwaltbare MVP-Group.</p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/admin?user=<%= activeUser.key %>">Back to Admin</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Group Detail</h3>
    <a class="button-secondary" href="/admin/groups/<%= adminGroupDetail.group.id %>/edit?user=<%= activeUser.key %>">Edit Group</a>
  </div>
  <div class="grid two-up detail-grid">
    <article class="subpanel">
      <h4>Name</h4>
      <p><%= adminGroupDetail.group.name %></p>
    </article>
    <article class="subpanel">
      <h4>Key</h4>
      <p><%= adminGroupDetail.group.key %></p>
    </article>
    <article class="subpanel">
      <h4>Description</h4>
      <p><%= adminGroupDetail.group.description ?? "Keine Beschreibung" %></p>
    </article>
    <article class="subpanel">
      <h4>Status</h4>
      <p><span class="status-pill status-<%= adminGroupDetail.group.status %>"><%= adminGroupDetail.group.status %></span></p>
    </article>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Members</h3>
    <p class="panel-copy">Aktuelle Memberships dieser Group.</p>
  </div>
  <% if (adminGroupDetail.memberships.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Members vorhanden.</strong>
      <p>Neue Memberships werden im ersten Schnitt ueber die jeweilige User-Detailseite angelegt.</p>
    </div>
  <% } else { %>
    <ul class="stack-list compact">
      <% adminGroupDetail.memberships.forEach(({ membership, user }) => { %>
        <li>
          <strong>
            <% if (user) { %>
              <a class="text-link" href="/admin/users/<%= user.id %>?user=<%= activeUser.key %>"><%= user.displayName %></a>
            <% } else { %>
              <%= membership.userId %>
            <% } %>
          </strong>
          <p>
            <%= user?.key ?? membership.userId %>
            · r:<%= membership.rights.read ? "yes" : "no" %>
            · w:<%= membership.rights.write ? "yes" : "no" %>
            · x:<%= membership.rights.execute ? "yes" : "no" %>
          </p>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Template Assignments</h3>
      <p class="panel-copy">Templates, die diese Group aktuell sehen darf.</p>
    </div>
    <% if (adminGroupDetail.templateAssignments.length === 0) { %>
      <div class="empty-state">
        <strong>Keine Template Assignments vorhanden.</strong>
        <p>Diese Group ist aktuell keinem Form Template zugeordnet.</p>
      </div>
    <% } else { %>
      <ul class="stack-list compact">
        <% adminGroupDetail.templateAssignments.forEach(({ assignment, template }) => { %>
          <li class="action-row">
            <div>
              <strong>
                <% if (template) { %>
                  <a class="text-link" href="/templates/<%= template.id %>?user=<%= activeUser.key %>"><%= template.name %></a>
                <% } else { %>
                  <%= assignment.templateId %>
                <% } %>
              </strong>
              <p>
                <%= template?.key ?? assignment.templateId %>
                <% if (template) { %> · v<%= template.version %> · <%= template.status %><% } %>
                · <%= assignment.status %>
              </p>
            </div>
            <form method="post" action="/admin/groups/<%= adminGroupDetail.group.id %>/template-assignments/<%= assignment.id %>/remove?user=<%= activeUser.key %>">
              <button class="button-secondary" type="submit">Remove</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Assign Template</h3>
      <p class="panel-copy">Kleiner erster Zuordnungspfad von der Group zum Form Template.</p>
    </div>
    <% if (adminGroupDetail.availableTemplates.length === 0) { %>
      <div class="empty-state">
        <strong>Keine weiteren Templates verfuegbar.</strong>
        <p>Alle aktuellen Templates sind dieser Group bereits zugeordnet.</p>
      </div>
    <% } else { %>
      <form method="post" action="/admin/groups/<%= adminGroupDetail.group.id %>/template-assignments?user=<%= activeUser.key %>" class="form-stack">
        <div class="field-block">
          <label class="field-label" for="template-assignment-template-id">Template</label>
          <select id="template-assignment-template-id" name="templateId" required>
            <option value="">Bitte Template auswaehlen</option>
            <% adminGroupDetail.availableTemplates.forEach((template) => { %>
              <option value="<%= template.id %>"><%= template.name %> (<%= template.key %> · v<%= template.version %>)</option>
            <% }) %>
          </select>
        </div>
        <button class="button-primary" type="submit">Assign Template</button>
      </form>
    <% } %>
  </article>
</section>
