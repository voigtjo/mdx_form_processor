<section class="hero-card hero-card-compact api-catalog-hero">
  <div>
    <h2><%= t("apis.title") %></h2>
    <p class="hero-inline-meta"><%= apiCatalog.operations.length %> APIs</p>
  </div>
  <div class="hero-actions">
    <% if (permissions.canEditApis) { %>
      <a class="button-primary" href="<%= hrefWithContext('/apis/new') %>"><%= t("apis.new") %></a>
    <% } %>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3><%= t("apis.title") %></h3>
    <span><%= apiCatalog.operations.length %> APIs</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Titel</th>
          <th>Key</th>
          <th>Status</th>
          <th>Typ</th>
          <th>Nutzung</th>
          <th>Aktion</th>
        </tr>
      </thead>
      <tbody>
        <% if (apiCatalog.operations.length === 0) { %>
          <tr>
            <td colspan="6"><span class="table-meta"><%= t("apis.none") %></span></td>
          </tr>
        <% } %>
        <% apiCatalog.operations.forEach(({ operation, templateUsages, workflowUsages, documentCount }) => { %>
          <tr>
            <td><strong><a class="text-link" href="<%= hrefWithContext(`/apis/${operation.id}`) %>"><%= operation.title %></a></strong></td>
            <td><code><%= operation.key %></code></td>
            <td><%= operation.status %></td>
            <td><%= operation.connector %></td>
            <td><%= documentCount %> Vorgänge · <%= templateUsages.length %> F · <%= workflowUsages.length %> W</td>
            <td>
              <div class="table-actions">
                <a class="text-link" href="<%= hrefWithContext(`/apis/${operation.id}`) %>"><%= t("apis.open") %></a>
                <% if (permissions.canEditApis && operation.status !== "archived") { %>
                  <form method="post" action="<%= hrefWithContext(`/apis/${operation.id}/edit`) %>" class="inline-form compact">
                    <button class="button-secondary" type="submit">Bearbeiten</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
