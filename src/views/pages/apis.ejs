<section class="hero-card hero-card-compact api-catalog-hero">
  <div>
    <h2>API-Liste</h2>
    <p class="hero-inline-meta"><%= apiCatalog.operations.length %> APIs</p>
  </div>
  <div class="hero-actions">
    <a class="button-primary" href="/apis/new?user=<%= activeUser.key %>">Neue API</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>API-Liste</h3>
    <span><%= apiCatalog.operations.length %> APIs</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Titel</th>
          <th>Key</th>
          <th>Status</th>
          <th>Typ</th>
          <th>Nutzung</th>
          <th>Aktion</th>
        </tr>
      </thead>
      <tbody>
        <% if (apiCatalog.operations.length === 0) { %>
          <tr>
            <td colspan="6"><span class="table-meta">Noch keine APIs vorhanden.</span></td>
          </tr>
        <% } %>
        <% apiCatalog.operations.forEach(({ operation, templateUsages, workflowUsages, documentCount }) => { %>
          <tr>
            <td><strong><a class="text-link" href="/apis/<%= operation.id %>?user=<%= activeUser.key %>"><%= operation.title %></a></strong></td>
            <td><code><%= operation.key %></code></td>
            <td><%= operation.status %></td>
            <td><%= operation.connector %></td>
            <td><%= documentCount %> Vorg. · <%= templateUsages.length %> T · <%= workflowUsages.length %> W</td>
            <td><a class="text-link" href="/apis/<%= operation.id %>?user=<%= activeUser.key %>">Oeffnen</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
