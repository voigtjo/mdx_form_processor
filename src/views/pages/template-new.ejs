<section class="hero-card">
  <div>
    <span class="eyebrow">Formulare</span>
    <h2>Neues Formular</h2>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="<%= hrefWithContext('/templates') %>">Zur Formularliste</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Entwurf anlegen</h3>
  </div>
  <form method="post" action="<%= hrefWithContext('/templates/new') %>" class="form-stack">
    <div class="field-block">
      <label class="field-label" for="template-name">Name</label>
      <input id="template-name" name="name" type="text" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="template-key">Key</label>
      <input id="template-key" name="key" type="text" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="template-description">Beschreibung</label>
      <textarea id="template-description" name="description" rows="4"></textarea>
    </div>
    <div class="field-block">
      <label class="field-label" for="template-form-type">Form Type</label>
      <select id="template-form-type" name="formType" required>
        <% availableFormTypes.forEach((formType) => { %>
          <option value="<%= formType.value %>"><%= formType.label %></option>
        <% }) %>
      </select>
    </div>
    <div class="field-block">
      <label class="field-label" for="template-workflow">Workflow-Zuordnung</label>
      <select id="template-workflow" name="workflowTemplateId" required>
        <% availableWorkflows.forEach((workflow) => { %>
          <option value="<%= workflow.id %>"><%= workflow.name %> (<%= workflow.key %>)</option>
        <% }) %>
      </select>
    </div>
    <button class="button-primary" type="submit">Entwurf anlegen</button>
  </form>
</section>
