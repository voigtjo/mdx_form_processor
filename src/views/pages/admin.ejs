<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2>Admin</h2>
    <p>Verwaltungsstart fuer Users, Groups, Memberships und Template Assignments ohne technische Ueberladung.</p>
  </div>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Users</h3>
      <a class="button-secondary" href="/admin/users/new?user=<%= activeUser.key %>">New User</a>
    </div>
    <ul class="stack-list compact">
      <% users.forEach((user) => { %>
        <li class="action-row">
          <div>
            <strong><a class="text-link" href="/admin/users/<%= user.id %>?user=<%= activeUser.key %>"><%= user.displayName %></a></strong>
            <p><%= user.key %> · <%= user.email ?? "keine E-Mail" %> · <%= user.status %></p>
          </div>
          <a class="text-link action-link" href="/admin/users/<%= user.id %>?user=<%= activeUser.key %>">View</a>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Groups</h3>
      <a class="button-secondary" href="/admin/groups/new?user=<%= activeUser.key %>">New Group</a>
    </div>
    <ul class="stack-list compact">
      <% catalog.groups.forEach((group) => { %>
        <li class="action-row">
          <div>
            <strong><a class="text-link" href="/admin/groups/<%= group.id %>?user=<%= activeUser.key %>"><%= group.name %></a></strong>
            <p><%= group.key %> · <%= group.description ?? "Keine Beschreibung" %> · <%= group.status %></p>
          </div>
          <a class="text-link action-link" href="/admin/groups/<%= group.id %>?user=<%= activeUser.key %>">View</a>
        </li>
      <% }) %>
    </ul>
  </article>
</section>

<section class="grid two-up">
  <article class="panel subtle">
    <h3>Memberships</h3>
    <p class="panel-copy">Pflege im ersten Schnitt ueber die jeweilige User-Detailseite.</p>
    <ul class="stack-list compact">
      <% catalog.memberships.forEach((membership) => { %>
        <% const user = users.find((entry) => entry.id === membership.userId); %>
        <% const group = catalog.groups.find((entry) => entry.id === membership.groupId); %>
        <li>
          <strong>
            <% if (user) { %>
              <a class="text-link" href="/admin/users/<%= user.id %>?user=<%= activeUser.key %>"><%= user.displayName %></a>
            <% } else { %>
              <%= membership.userId %>
            <% } %>
          </strong>
          <p><%= group?.name ?? membership.groupId %> · r:<%= membership.rights.read ? "yes" : "no" %> · w:<%= membership.rights.write ? "yes" : "no" %> · x:<%= membership.rights.execute ? "yes" : "no" %></p>
        </li>
      <% }) %>
    </ul>
  </article>
  <article class="panel subtle">
    <h3>Template Assignments</h3>
    <p class="panel-copy">Pflege im ersten Schnitt ueber die jeweilige Group-Detailseite.</p>
    <ul class="stack-list compact">
      <% catalog.templateAssignments.forEach((assignment) => { %>
        <% const template = catalog.templates.find((entry) => entry.id === assignment.templateId); %>
        <% const group = catalog.groups.find((entry) => entry.id === assignment.groupId); %>
        <li>
          <strong>
            <% if (template) { %>
              <a class="text-link" href="/templates/<%= template.id %>?user=<%= activeUser.key %>"><%= template.name %></a>
            <% } else { %>
              <%= assignment.templateId %>
            <% } %>
          </strong>
          <p>
            <% if (group) { %>
              <a class="text-link" href="/admin/groups/<%= group.id %>?user=<%= activeUser.key %>"><%= group.name %></a>
            <% } else { %>
              <%= assignment.groupId %>
            <% } %>
            · <%= assignment.status %>
          </p>
        </li>
      <% }) %>
    </ul>
  </article>
</section>
