<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2>Admin</h2>
    <p>Verwaltungsstart fuer Users, Groups, Memberships und Template Assignments ohne technische Ueberladung.</p>
  </div>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Users</h3>
      <button class="button-secondary" type="button">New User</button>
    </div>
    <ul class="stack-list compact">
      <% users.forEach((user) => { %>
        <li>
          <strong><%= user.displayName %></strong>
          <p><%= user.key %> · <%= user.email ?? "keine E-Mail" %> · <%= user.status %></p>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Groups</h3>
      <button class="button-secondary" type="button">New Group</button>
    </div>
    <ul class="stack-list compact">
      <% catalog.groups.forEach((group) => { %>
        <li>
          <strong><%= group.name %></strong>
          <p><%= group.key %> · <%= group.description ?? "Keine Beschreibung" %></p>
        </li>
      <% }) %>
    </ul>
  </article>
</section>

<section class="grid two-up">
  <article class="panel subtle">
    <h3>Memberships</h3>
    <ul class="stack-list compact">
      <% catalog.memberships.forEach((membership) => { %>
        <% const user = users.find((entry) => entry.id === membership.userId); %>
        <% const group = catalog.groups.find((entry) => entry.id === membership.groupId); %>
        <li>
          <strong><%= user?.displayName ?? membership.userId %></strong>
          <p><%= group?.name ?? membership.groupId %> · r:<%= membership.rights.read ? "yes" : "no" %> · w:<%= membership.rights.write ? "yes" : "no" %> · x:<%= membership.rights.execute ? "yes" : "no" %></p>
        </li>
      <% }) %>
    </ul>
  </article>
  <article class="panel subtle">
    <h3>Template Assignments</h3>
    <ul class="stack-list compact">
      <% catalog.templateAssignments.forEach((assignment) => { %>
        <% const template = catalog.templates.find((entry) => entry.id === assignment.templateId); %>
        <% const group = catalog.groups.find((entry) => entry.id === assignment.groupId); %>
        <li>
          <strong><%= template?.name ?? assignment.templateId %></strong>
          <p><%= group?.name ?? assignment.groupId %> · <%= assignment.status %></p>
        </li>
      <% }) %>
    </ul>
  </article>
</section>
