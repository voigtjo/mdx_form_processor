<section class="hero-card hero-card-compact">
  <div>
    <h2>Admin</h2>
    <p>Benutzer, globale Rechte und Zuordnungen werden hier pro ausgewähltem Benutzer gepflegt.</p>
  </div>
  <div class="hero-actions">
    <a class="button-primary" href="<%= hrefWithContext('/admin/users/new') %>">Neuer Benutzer</a>
  </div>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Benutzer</h3>
      <span class="chip"><%= users.length %></span>
    </div>
    <ul class="stack-list compact">
      <% users.forEach((user) => { %>
        <li class="action-row">
          <div>
            <strong>
              <a class="text-link" href="<%= hrefWithContext('/admin', { selectedUser: user.id }) %>"><%= user.displayName %></a>
            </strong>
            <p><%= user.key %> · <%= user.email ?? "keine E-Mail" %> · <%= user.status %></p>
            <p class="table-meta">
              Admin: <%= user.globalRoles.admin ? "ja" : "nein" %>
              · Entwickler: <%= user.globalRoles.developer ? "ja" : "nein" %>
              · Chef: <%= user.globalRoles.chef ? "ja" : "nein" %>
            </p>
          </div>
          <% if (adminOverview.selectedUser?.id === user.id) { %>
            <span class="chip">Ausgewählt</span>
          <% } else { %>
            <a class="text-link action-link" href="<%= hrefWithContext('/admin', { selectedUser: user.id }) %>">Anzeigen</a>
          <% } %>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Benutzerdetail</h3>
      <% if (adminOverview.selectedUser) { %>
        <span class="chip"><%= adminOverview.selectedUser.displayName %></span>
      <% } %>
    </div>
    <% if (!adminOverview.selectedUser) { %>
      <div class="empty-state">
        <strong>Kein Benutzer ausgewählt.</strong>
        <p>Wähle links einen Benutzer aus, um ihn zu prüfen und zu pflegen.</p>
      </div>
    <% } else { %>
      <form method="post" action="<%= hrefWithContext(`/admin/users/${adminOverview.selectedUser.id}/edit`, { selectedUser: adminOverview.selectedUser.id }) %>" class="stack-form">
        <div class="form-grid two-up">
          <label>
            <span class="field-label">Anzeigename</span>
            <input class="text-input" type="text" name="displayName" value="<%= adminOverview.selectedUser.displayName %>" required />
          </label>
          <label>
            <span class="field-label">E-Mail</span>
            <input class="text-input" type="email" name="email" value="<%= adminOverview.selectedUser.email ?? "" %>" />
          </label>
          <label>
            <span class="field-label">Status</span>
            <select class="text-input" name="status">
              <option value="active" <%= adminOverview.selectedUser.status === "active" ? "selected" : "" %>>active</option>
              <option value="inactive" <%= adminOverview.selectedUser.status === "inactive" ? "selected" : "" %>>inactive</option>
            </select>
          </label>
          <label>
            <span class="field-label"><%= t("admin.language") %></span>
            <select class="text-input" name="locale">
              <option value="de" <%= adminOverview.selectedUser.locale === "de" ? "selected" : "" %>><%= t("language.de") %></option>
              <option value="en" <%= adminOverview.selectedUser.locale === "en" ? "selected" : "" %>><%= t("language.en") %></option>
            </select>
          </label>
        </div>

        <div class="choice-grid">
          <label class="filter-toggle">
            <input type="checkbox" name="roleAdmin" value="1" <%= adminOverview.selectedUser.globalRoles.admin ? "checked" : "" %> <%= permissions.canManageAdmins ? "" : "disabled" %> />
            <span>Admin</span>
          </label>
          <label class="filter-toggle">
            <input type="checkbox" name="roleDeveloper" value="1" <%= adminOverview.selectedUser.globalRoles.developer ? "checked" : "" %> />
            <span>Entwickler</span>
          </label>
          <label class="filter-toggle">
            <input type="checkbox" name="roleChef" value="1" <%= adminOverview.selectedUser.globalRoles.chef ? "checked" : "" %> />
            <span>Chef</span>
          </label>
        </div>

        <button class="button-primary" type="submit">Benutzer speichern</button>
      </form>

      <hr class="section-divider" />

      <div class="panel-header">
        <h3>Gruppenzuordnungen</h3>
        <span class="chip"><%= adminOverview.memberships.length %></span>
      </div>
      <% if (adminOverview.memberships.length === 0) { %>
        <div class="empty-state">
          <strong>Keine Gruppenzuordnung.</strong>
          <p>Dieser Benutzer ist derzeit keiner Gruppe zugeordnet.</p>
        </div>
      <% } else { %>
        <ul class="stack-list compact">
          <% adminOverview.memberships.forEach(({ membership, group }) => { %>
            <li class="action-row">
              <div>
                <strong><%= group?.name ?? membership.groupId %></strong>
                <p>
                  g-admin: <%= membership.rights.groupAdmin ? "ja" : "nein" %>
                  · r: <%= membership.rights.read ? "ja" : "nein" %>
                  · w: <%= membership.rights.write ? "ja" : "nein" %>
                  · x: <%= membership.rights.execute ? "ja" : "nein" %>
                </p>
              </div>
              <form method="post" action="<%= hrefWithContext(`/admin/users/${adminOverview.selectedUser.id}/memberships/${membership.id}/remove`, { selectedUser: adminOverview.selectedUser.id }) %>">
                <button class="button-secondary" type="submit">Entfernen</button>
              </form>
            </li>
          <% }) %>
        </ul>
      <% } %>

      <% if (adminOverview.availableGroups.length > 0) { %>
        <form method="post" action="<%= hrefWithContext(`/admin/users/${adminOverview.selectedUser.id}/memberships`, { selectedUser: adminOverview.selectedUser.id }) %>" class="stack-form">
          <label>
            <span class="field-label">Gruppe hinzufügen</span>
            <select class="text-input" name="groupId" required>
              <option value="">Bitte wählen</option>
              <% adminOverview.availableGroups.forEach((group) => { %>
                <option value="<%= group.id %>"><%= group.name %></option>
              <% }) %>
            </select>
          </label>
          <div class="choice-grid">
            <label class="filter-toggle"><input type="checkbox" name="rights" value="r" checked /> <span>Gruppen-Read</span></label>
            <label class="filter-toggle"><input type="checkbox" name="rights" value="w" /> <span>Gruppen-Write</span></label>
            <label class="filter-toggle"><input type="checkbox" name="rights" value="x" /> <span>Gruppen-Execute</span></label>
            <label class="filter-toggle"><input type="checkbox" name="rights" value="g" /> <span>Gruppenadmin</span></label>
          </div>
          <button class="button-secondary" type="submit">Gruppenzuordnung anlegen</button>
        </form>
      <% } %>
    <% } %>
  </article>
</section>
