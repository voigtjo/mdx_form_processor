<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2><%= adminUserDetail.user.displayName %></h2>
    <p>Kleine Einzelansicht fuer einen verwaltbaren MVP-User.</p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/admin?user=<%= activeUser.key %>">Back to Admin</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>User Detail</h3>
    <a class="button-secondary" href="/admin/users/<%= adminUserDetail.user.id %>/edit?user=<%= activeUser.key %>">Edit User</a>
  </div>
  <div class="grid two-up detail-grid">
    <article class="subpanel">
      <h4>Display Name</h4>
      <p><%= adminUserDetail.user.displayName %></p>
    </article>
    <article class="subpanel">
      <h4>Key</h4>
      <p><%= adminUserDetail.user.key %></p>
    </article>
    <article class="subpanel">
      <h4>E-Mail</h4>
      <p><%= adminUserDetail.user.email ?? "keine E-Mail" %></p>
    </article>
    <article class="subpanel">
      <h4>Status</h4>
      <p><span class="status-pill status-<%= adminUserDetail.user.status %>"><%= adminUserDetail.user.status %></span></p>
    </article>
  </div>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Memberships</h3>
      <p class="panel-copy">Groups und Grundrechte dieses Users.</p>
    </div>
    <% if (adminUserDetail.memberships.length === 0) { %>
      <div class="empty-state">
        <strong>Keine Memberships vorhanden.</strong>
        <p>Dieser User ist aktuell keiner Group zugeordnet.</p>
      </div>
    <% } else { %>
      <ul class="stack-list compact">
        <% adminUserDetail.memberships.forEach(({ membership, group }) => { %>
          <li class="action-row">
            <div>
              <strong>
                <% if (group) { %>
                  <a class="text-link" href="/admin/groups/<%= group.id %>?user=<%= activeUser.key %>"><%= group.name %></a>
                <% } else { %>
                  <%= membership.groupId %>
                <% } %>
              </strong>
              <p>
                <%= group?.key ?? membership.groupId %>
                · r:<%= membership.rights.read ? "yes" : "no" %>
                · w:<%= membership.rights.write ? "yes" : "no" %>
                · x:<%= membership.rights.execute ? "yes" : "no" %>
              </p>
            </div>
            <form method="post" action="/admin/users/<%= adminUserDetail.user.id %>/memberships/<%= membership.id %>/remove?user=<%= activeUser.key %>">
              <button class="button-secondary" type="submit">Remove</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Add Membership</h3>
      <p class="panel-copy">Kleiner erster Zuordnungspfad vom User zur Group.</p>
    </div>
    <% if (adminUserDetail.availableGroups.length === 0) { %>
      <div class="empty-state">
        <strong>Keine weiteren Groups verfuegbar.</strong>
        <p>Alle aktuellen Groups sind diesem User bereits zugeordnet.</p>
      </div>
    <% } else { %>
      <form method="post" action="/admin/users/<%= adminUserDetail.user.id %>/memberships?user=<%= activeUser.key %>" class="form-stack">
        <div class="field-block">
          <label class="field-label" for="membership-group-id">Group</label>
          <select id="membership-group-id" name="groupId" required>
            <option value="">Bitte Group auswaehlen</option>
            <% adminUserDetail.availableGroups.forEach((group) => { %>
              <option value="<%= group.id %>"><%= group.name %> (<%= group.key %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="field-block">
          <span class="field-label">Rights</span>
          <div class="checkbox-list">
            <label class="checkbox-item">
              <input type="checkbox" name="rights" value="r" checked />
              <span>Read (r)</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="rights" value="w" checked />
              <span>Write (w)</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="rights" value="x" />
              <span>Execute (x)</span>
            </label>
          </div>
        </div>
        <button class="button-primary" type="submit">Add Membership</button>
      </form>
    <% } %>
  </article>
</section>
