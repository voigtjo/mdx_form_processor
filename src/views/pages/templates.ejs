<section class="hero-card">
  <div>
    <h2>Formulare</h2>
    <p>Formulare fuer Serviceeinsaetze, Produktion, Nachweise und generische Freigaben.</p>
  </div>
  <div class="hero-actions">
    <a class="button-primary" href="/templates/new?user=<%= activeUser.key %>">Neues Formular</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Formularliste</h3>
  </div>
  <% if (catalog.templates.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Formulare sichtbar.</strong>
      <p>Im aktuellen Konfigurationskontext gibt es keine sichtbaren Formulare.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Template</th>
            <th>Workflow</th>
            <th>Groups</th>
            <th>Status</th>
            <th>Version</th>
            <th>Usage</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
            <% catalog.templates.forEach((template) => { %>
              <% const workflow = catalog.workflows.find((item) => item.id === template.workflowTemplateId); %>
              <% const groupNames = catalog.groups.filter((group) => template.groupIds.includes(group.id)).map((group) => group.name); %>
              <% const documentCount = catalog.documents.filter((document) => document.templateId === template.id).length; %>
            <tr>
              <td>
                <strong><a class="text-link" href="/templates/<%= template.id %>?user=<%= activeUser.key %>"><%= template.name %></a></strong>
                <p class="table-meta"><%= template.key %></p>
              </td>
              <td>
                <strong><%= workflow?.name ?? "Nicht zugeordnet" %></strong>
                <p class="table-meta"><%= workflow?.key ?? "ohne Workflow-Key" %><% if (workflow) { %> · v<%= workflow.version %><% } %></p>
              </td>
              <td><%= groupNames.length > 0 ? groupNames.join(", ") : "Keine Group-Zuordnung" %></td>
              <td><span class="status-pill status-<%= template.status %>"><%= template.status %></span></td>
              <td>v<%= template.version %></td>
              <td><%= documentCount %> Vorgaenge</td>
              <td>
                <div class="table-actions">
                  <a class="text-link" href="/templates/<%= template.id %>?user=<%= activeUser.key %>">Oeffnen</a>
                  <a class="text-link" href="/documents?user=<%= activeUser.key %>&q=<%= encodeURIComponent(template.key) %>">Vorgaenge</a>
                  <% if (template.status === "published" && workflow?.status === "published") { %>
                    <form method="post" action="/documents/start?user=<%= activeUser.key %>" class="inline-form compact">
                      <input type="hidden" name="templateId" value="<%= template.id %>" />
                      <button class="button-secondary" type="submit">Starten</button>
                    </form>
                  <% } else { %>
                    <span class="table-meta">Nicht startbar</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
