<section class="hero-card">
  <div>
    <h2><%= t("templates.title") %></h2>
    <p><%= t("templates.subtitle") %></p>
  </div>
  <% if (permissions.canEditTemplatesAndWorkflows) { %>
    <div class="hero-actions">
      <a class="button-primary" href="<%= hrefWithContext('/templates/new') %>"><%= t("templates.new") %></a>
    </div>
  <% } %>
</section>

<section class="panel">
  <div class="panel-header">
    <h3><%= t("templates.list") %></h3>
  </div>
  <% if (catalog.templates.length === 0) { %>
    <div class="empty-state">
      <strong><%= t("templates.noneTitle") %></strong>
      <p><%= t("templates.noneText") %></p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t("documents.formLabel") %></th>
            <th>Workflow</th>
            <th>Gruppen</th>
            <th>Status</th>
            <th>Version</th>
            <th>Nutzung</th>
            <th>Aktionen</th>
          </tr>
        </thead>
        <tbody>
            <% catalog.templates.forEach((template) => { %>
              <% const workflow = catalog.workflows.find((item) => item.id === template.workflowTemplateId); %>
              <% const groupNames = catalog.groups.filter((group) => template.groupIds.includes(group.id)).map((group) => group.name); %>
              <% const documentCount = catalog.documents.filter((document) => document.templateId === template.id).length; %>
              <% const siblingDraft = catalog.templates.find((item) => item.key === template.key && item.status === "draft"); %>
            <tr>
              <td>
                <strong><a class="text-link" href="<%= hrefWithContext(`/templates/${template.id}`) %>"><%= template.name %></a></strong>
                <p class="table-meta"><%= template.key %></p>
                <% if (template.status === "published" && siblingDraft && siblingDraft.id !== template.id) { %>
                  <p class="table-meta">Draft v<%= siblingDraft.version %> vorhanden</p>
                <% } %>
              </td>
              <td>
                <strong><%= workflow?.name ?? t("templates.workflowUnassigned") %></strong>
                <p class="table-meta"><%= workflow?.key ?? t("templates.noWorkflowKey") %><% if (workflow) { %> · v<%= workflow.version %><% } %></p>
              </td>
              <td><%= groupNames.length > 0 ? groupNames.join(", ") : t("templates.noGroupAssignment") %></td>
              <td><span class="status-pill status-<%= template.status %>"><%= template.status %></span></td>
              <td>v<%= template.version %></td>
              <td><%= documentCount %> <%= t("templates.documents") %></td>
              <td>
                <div class="table-actions">
                  <a class="text-link" href="<%= hrefWithContext(`/templates/${template.id}`) %>"><%= t("templates.open") %></a>
                  <% if (permissions.canEditTemplatesAndWorkflows) { %>
                    <form method="post" action="<%= hrefWithContext(`/templates/${template.id}/edit`) %>" class="inline-form compact">
                      <button class="button-secondary" type="submit">Bearbeiten</button>
                    </form>
                  <% } %>
                  <a class="text-link" href="<%= hrefWithContext('/documents', { template: template.id }) %>"><%= t("templates.documents") %></a>
                  <% if (workspaceSummary.startableTemplateIds.includes(template.id) && template.status === "published" && workflow?.status === "published") { %>
                    <form method="post" action="<%= hrefWithContext('/documents/start') %>" class="inline-form compact">
                      <input type="hidden" name="templateId" value="<%= template.id %>" />
                      <button class="button-secondary" type="submit"><%= t("documents.start") %></button>
                    </form>
                  <% } else { %>
                    <span class="table-meta"><%= t("templates.notStartable") %></span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
