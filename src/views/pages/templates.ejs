<section class="hero-card">
  <div>
    <span class="eyebrow">Konfigurations-UI</span>
    <h2>Templates</h2>
    <p>Finder fuer sichtbare Form Templates mit Workflow-Bezug, Group-Zuordnung und Einstieg in Detail, Documents und den heutigen MVP-Startpfad.</p>
  </div>
  <div class="hero-actions">
    <a class="button-primary" href="/templates/new?user=<%= activeUser.key %>">New Template</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Templates List</h3>
    <p class="panel-copy">Lesbare Konfigurationsliste mit Detailsprung statt Inline-Review unter der Tabelle.</p>
  </div>
  <% if (catalog.templates.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Templates sichtbar.</strong>
      <p>Im aktuellen Konfigurationskontext gibt es keine sichtbaren Form Templates.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Template</th>
            <th>Workflow</th>
            <th>Groups</th>
            <th>Status</th>
            <th>Version</th>
            <th>Usage</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% catalog.templates.forEach((template) => { %>
            <% const workflow = catalog.workflows.find((item) => item.id === template.workflowTemplateId); %>
            <% const groupNames = catalog.groups.filter((group) => template.groupIds.includes(group.id)).map((group) => group.name); %>
            <% const documentCount = catalog.documents.filter((document) => document.templateId === template.id).length; %>
            <tr>
              <td>
                <strong><a class="text-link" href="/templates/<%= template.id %>?user=<%= activeUser.key %>"><%= template.name %></a></strong>
                <p class="table-meta"><%= template.key %></p>
                <% if (template.description) { %>
                  <p class="table-meta"><%= template.description %></p>
                <% } %>
              </td>
              <td>
                <strong><%= workflow?.name ?? "Nicht zugeordnet" %></strong>
                <p class="table-meta"><%= workflow?.key ?? "ohne Workflow-Key" %></p>
              </td>
              <td><%= groupNames.length > 0 ? groupNames.join(", ") : "Keine Group-Zuordnung" %></td>
              <td><span class="status-pill status-<%= template.status %>"><%= template.status %></span></td>
              <td>v<%= template.version %></td>
              <td><%= documentCount %> Documents</td>
              <td>
                <div class="table-actions">
                  <a class="text-link" href="/templates/<%= template.id %>?user=<%= activeUser.key %>">View</a>
                  <a class="text-link" href="/documents?user=<%= activeUser.key %>&q=<%= encodeURIComponent(template.key) %>">Open Documents</a>
                  <% if (template.status === "published") { %>
                    <form method="post" action="/documents/start?user=<%= activeUser.key %>" class="inline-form compact">
                      <input type="hidden" name="templateId" value="<%= template.id %>" />
                      <button class="button-secondary" type="submit">Start Document</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
