<section class="hero-card">
  <div>
    <span class="eyebrow">Konfigurations-UI</span>
    <h2>Templates</h2>
    <p>Review- und Einstiegssicht fuer MDX-Form-Templates, Group-Zuweisungen und Versionen.</p>
  </div>
  <div class="hero-actions">
    <button class="button-primary" type="button">New Template</button>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Templates List</h3>
    <p class="panel-copy">Minimaler Start mit Sicht auf Name, Key, Version, Status, Workflow und Group-Zuordnung.</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Key</th>
          <th>Workflow</th>
          <th>Groups</th>
          <th>Status</th>
          <th>Version</th>
        </tr>
      </thead>
      <tbody>
        <% catalog.templates.forEach((template) => { %>
          <% const workflow = catalog.workflows.find((item) => item.id === template.workflowTemplateId); %>
          <% const groupNames = catalog.groups.filter((group) => template.groupIds.includes(group.id)).map((group) => group.name).join(", "); %>
          <tr>
            <td><%= template.name %></td>
            <td><%= template.key %></td>
            <td><%= workflow?.name ?? "Nicht zugeordnet" %></td>
            <td><%= groupNames %></td>
            <td><span class="status-pill status-<%= template.status %>"><%= template.status %></span></td>
            <td>v<%= template.version %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="grid three-up">
  <article class="panel subtle">
    <h3>Overview</h3>
    <p>Platz fuer lesbare Template-Metadaten, Keys, Tabellenfelder und Group-Zuweisungen.</p>
  </article>
  <article class="panel subtle">
    <h3>Form</h3>
    <p>Platz fuer MDX-Review, Felduebersicht und spaetere Vorschau.</p>
  </article>
  <article class="panel subtle">
    <h3>Workflow</h3>
    <p>Platz fuer verlinkte Workflow-Zusammenfassung ohne konkurrierendes Modell.</p>
  </article>
</section>

