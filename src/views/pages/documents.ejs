<section class="hero-card">
  <div>
    <h2><%= t("documents.title") %></h2>
    <p><%= t("documents.subtitle") %></p>
  </div>
  <div class="hero-metrics">
    <article>
      <strong><%= documentsList.summary.filteredCount %></strong>
      <span>Sichtbar</span>
    </article>
    <article>
      <strong><%= documentsList.summary.activeCount %></strong>
      <span>Aktiv</span>
    </article>
    <article>
      <strong><%= documentsList.summary.archivedCount %></strong>
      <span>Archiv</span>
    </article>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3><%= t("documents.selection") %></h3>
    <span class="chip"><%= selectedGroup?.name ?? activeUser.displayName %></span>
  </div>
  <p class="panel-copy"><%= t("documents.selectionHelp") %></p>
  <div class="hero-actions">
    <form method="get" action="/documents" class="inline-form">
      <input type="hidden" name="user" value="<%= activeUser.key %>" />
      <% if (selectedGroup) { %><input type="hidden" name="group" value="<%= selectedGroup.key %>" /><% } %>
      <label class="sr-only" for="templateId"><%= t("documents.formLabel") %></label>
      <select id="templateId" name="template">
        <option value=""><%= t("documents.allForms") %></option>
        <% selectableTemplates.forEach(({ key, representative, workflow, hasDraft, hasPublished }) => { %>
          <option value="<%= key %>" <%= selectedTemplateKey === key ? "selected" : "" %>><%= representative.name %> · <%= hasPublished ? "published" : representative.status %> · v<%= representative.version %><% if (hasDraft && representative.status === "published") { %> · Draft vorhanden<% } %> · <%= workflow?.name ?? "Workflow" %> (v<%= workflow?.version ?? "?" %>)</option>
        <% }) %>
      </select>
      <button class="button-secondary" type="submit"><%= t("documents.show") %></button>
      <button class="button-primary" type="submit" formmethod="post" formaction="<%= hrefWithContext('/documents/start') %>" <%= !selectedTemplateIdForStart || !workspaceSummary.startableTemplateIds.includes(selectedTemplateIdForStart) ? "disabled" : "" %>><%= t("documents.start") %></button>
      <% if (selectedTemplateIdForStart) { %>
        <input type="hidden" name="templateId" value="<%= selectedTemplateIdForStart %>" />
      <% } %>
    </form>
  </div>
  <% if (selectedTemplateKey) { %>
    <p class="field-help">Aktuell gefiltert nach Formularfamilie <strong><%= selectedTemplateKey %></strong>. Angezeigt werden alle nicht archivierten Vorgänge dieses Formulars über alle sichtbaren Versionen.</p>
  <% } %>
</section>

<% if (typeof startError === "string" && startError.length > 0) { %>
  <section class="panel subtle">
    <div class="panel-header">
      <h3>Start nicht möglich</h3>
      <span class="chip"><%= activeUser.displayName %></span>
    </div>
    <p><%= startError %></p>
  </section>
<% } %>

<section class="panel">
  <div class="panel-header">
    <h3><%= t("documents.list") %></h3>
    <span class="chip"><%= documentsList.summary.filteredCount %></span>
  </div>

  <form method="get" action="/documents" class="filter-form">
    <input type="hidden" name="user" value="<%= activeUser.key %>" />
    <% if (selectedGroup) { %><input type="hidden" name="group" value="<%= selectedGroup.key %>" /><% } %>
    <input type="hidden" name="template" value="<%= documentsList.filterState.templateKey ?? "" %>" />
    <div class="filter-grid">
      <div>
        <label class="field-label" for="documents-q">Suche</label>
        <input id="documents-q" type="search" name="q" value="<%= documentsList.filterState.q %>" placeholder="Einsatznummer, Batch, Nachweisnummer oder Titel" />
      </div>
      <div>
        <label class="field-label" for="documents-status">Status</label>
        <select id="documents-status" name="status">
          <option value="">Alle sichtbaren Status</option>
          <% documentsList.availableStatuses.forEach((status) => { %>
            <option value="<%= status %>" <%= documentsList.filterState.status === status ? "selected" : "" %>><%= status %></option>
          <% }) %>
        </select>
      </div>
      <label class="filter-toggle">
        <input type="checkbox" name="showArchived" value="1" <%= documentsList.filterState.showArchived ? "checked" : "" %> />
        <span>Archiv einbeziehen</span>
      </label>
      <div class="filter-actions">
        <button class="button-secondary" type="submit">Filtern</button>
        <a class="text-link" href="<%= hrefWithContext('/documents') %>">Reset</a>
      </div>
    </div>
  </form>
  <% if (documentsList.documents.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Vorgänge gefunden.</strong>
      <p>Die aktuelle Kombination aus Suche, Status und Archivfilter liefert keine Treffer.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Vorgang</th>
            <th>Formular</th>
            <th>Workflow</th>
            <th>Status</th>
            <th>Zugewiesen</th>
            <th>Aktualisiert</th>
            <th>Öffnen</th>
          </tr>
        </thead>
        <tbody>
          <% documentsList.documents.forEach((document) => { %>
            <% const template = catalog.templates.find((item) => item.id === document.templateId); %>
            <% const workflow = template ? catalog.workflows.find((item) => item.id === template.workflowTemplateId) : undefined; %>
            <% const assignedUsers = users.filter((user) => document.assignedUserIds.includes(user.id)).map((user) => user.displayName).join(", "); %>
            <tr>
              <td>
                <a class="text-link" href="<%= hrefWithContext(`/documents/${document.id}`) %>"><%= document.title %></a>
                <p class="table-meta">
                  <%= document.status === "archived" ? "Archiviert" : "Aktiv" %>
                  <% if (document.typedLeadField && document.typedLeadValue) { %>
                    · <%= document.typedLeadField === "order_number" ? "Einsatznummer" : document.typedLeadField %>: <%= document.typedLeadValue %>
                  <% } %>
                  <% if (document.typedTableName) { %>
                    · <%= document.typedTableName %>
                  <% } %>
                </p>
              </td>
              <td>
                <strong><%= template?.name ?? "Unbekannt" %></strong>
                <p class="table-meta"><%= template?.key ?? "ohne Formular-Key" %><% if (template) { %> · <%= template.formType %> · v<%= template.version %><% } %></p>
              </td>
              <td>
                <strong><%= workflow?.name ?? "Unbekannt" %></strong>
                <p class="table-meta"><%= workflow?.key ?? "ohne Workflow-Key" %><% if (workflow) { %> · v<%= workflow.version %><% } %></p>
              </td>
              <td><span class="status-pill"><%= document.status %></span></td>
              <td><%= assignedUsers || "Keine aktiven Zuweisungen" %></td>
              <td><%= document.updatedAt %></td>
              <td><a class="text-link" href="<%= hrefWithContext(`/documents/${document.id}`) %>">Öffnen</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
