<section class="hero-card">
  <div>
    <h2>Documents</h2>
  </div>
  <div class="hero-metrics">
    <article>
      <strong><%= documentsList.summary.filteredCount %></strong>
      <span>Sichtbar</span>
    </article>
    <article>
      <strong><%= documentsList.summary.activeCount %></strong>
      <span>Aktiv</span>
    </article>
    <article>
      <strong><%= documentsList.summary.archivedCount %></strong>
      <span>Archiv</span>
    </article>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Neues Document</h3>
    <span class="chip"><%= activeUser.displayName %></span>
  </div>
  <% const startableTemplates = workspaceSummary.templates
    .map((template) => ({
      template,
      workflow: catalog.workflows.find((workflow) => workflow.id === template.workflowTemplateId),
    }))
    .filter(({ template, workflow }) => template.status === "published" && workflow?.status === "published"); %>
  <div class="hero-actions">
    <form method="post" action="/documents/start?user=<%= activeUser.key %>" class="inline-form">
      <label class="sr-only" for="templateId">Template</label>
      <select id="templateId" name="templateId">
        <% startableTemplates.forEach(({ template, workflow }) => { %>
          <option value="<%= template.id %>"><%= template.name %> (v<%= template.version %>) · <%= workflow?.name ?? "Workflow" %> (v<%= workflow?.version ?? "?" %>)</option>
        <% }) %>
      </select>
      <button class="button-primary" type="submit" <%= startableTemplates.length === 0 ? "disabled" : "" %>>Starten</button>
    </form>
  </div>
</section>

<% if (typeof startError === "string" && startError.length > 0) { %>
  <section class="panel subtle">
    <div class="panel-header">
      <h3>Start Error</h3>
      <span class="chip"><%= activeUser.displayName %></span>
    </div>
    <p><%= startError %></p>
  </section>
<% } %>

<section class="panel">
  <div class="panel-header">
    <h3>Documents</h3>
    <span class="chip"><%= documentsList.summary.filteredCount %></span>
  </div>

  <form method="get" action="/documents" class="filter-form">
    <input type="hidden" name="user" value="<%= activeUser.key %>" />
    <div class="filter-grid">
      <div>
        <label class="field-label" for="documents-q">Suche</label>
        <input id="documents-q" type="search" name="q" value="<%= documentsList.filterState.q %>" placeholder="Titel, order_number, batch_id, qualification_record_number oder form_title" />
      </div>
      <div>
        <label class="field-label" for="documents-status">Status</label>
        <select id="documents-status" name="status">
          <option value="">Alle sichtbaren Status</option>
          <% documentsList.availableStatuses.forEach((status) => { %>
            <option value="<%= status %>" <%= documentsList.filterState.status === status ? "selected" : "" %>><%= status %></option>
          <% }) %>
        </select>
      </div>
      <label class="filter-toggle">
        <input type="checkbox" name="showArchived" value="1" <%= documentsList.filterState.showArchived ? "checked" : "" %> />
        <span>Archiv einbeziehen</span>
      </label>
      <div class="filter-actions">
        <button class="button-secondary" type="submit">Filtern</button>
        <a class="text-link" href="/documents?user=<%= activeUser.key %>">Reset</a>
      </div>
    </div>
  </form>
  <% if (documentsList.documents.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Documents gefunden.</strong>
      <p>Die aktuelle Kombination aus Suche, Status und Archivfilter liefert keine Treffer.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Document</th>
            <th>Template</th>
            <th>Workflow</th>
            <th>Status</th>
            <th>Assigned Users</th>
            <th>Updated</th>
            <th>Open</th>
          </tr>
        </thead>
        <tbody>
          <% documentsList.documents.forEach((document) => { %>
            <% const template = catalog.templates.find((item) => item.id === document.templateId); %>
            <% const workflow = template ? catalog.workflows.find((item) => item.id === template.workflowTemplateId) : undefined; %>
            <% const assignedUsers = users.filter((user) => document.assignedUserIds.includes(user.id)).map((user) => user.displayName).join(", "); %>
            <tr>
              <td>
                <a class="text-link" href="/documents/<%= document.id %>?user=<%= activeUser.key %>"><%= document.title %></a>
                <p class="table-meta">
                  <%= document.status === "archived" ? "Archiviert" : "Aktiv" %>
                  <% if (document.typedLeadField && document.typedLeadValue) { %>
                    · <%= document.typedLeadField %>: <%= document.typedLeadValue %>
                  <% } %>
                  <% if (document.typedTableName) { %>
                    · <%= document.typedTableName %>
                  <% } %>
                </p>
              </td>
              <td>
                <strong><%= template?.name ?? "Unbekannt" %></strong>
                <p class="table-meta"><%= template?.key ?? "ohne Template-Key" %><% if (template) { %> · <%= template.formType %> · v<%= template.version %><% } %></p>
              </td>
              <td>
                <strong><%= workflow?.name ?? "Unbekannt" %></strong>
                <p class="table-meta"><%= workflow?.key ?? "ohne Workflow-Key" %><% if (workflow) { %> · v<%= workflow.version %><% } %></p>
              </td>
              <td><span class="status-pill"><%= document.status %></span></td>
              <td><%= assignedUsers || "Keine aktiven Assignments" %></td>
              <td><%= document.updatedAt %></td>
              <td><a class="text-link" href="/documents/<%= document.id %>?user=<%= activeUser.key %>">Open</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
