<section class="hero-card">
  <div>
    <h2>Arbeitsstart</h2>
    <p>Offene Serviceeinsaetze, Freigaben und startbare Formulare im aktuellen Einsatzkontext.</p>
  </div>
  <div class="hero-metrics">
    <article>
      <strong><%= workspaceSummary.groups.length %></strong>
      <span>Teams</span>
    </article>
    <article>
      <strong><%= workspaceSummary.tasks.length %></strong>
      <span>Offene Schritte</span>
    </article>
    <article>
      <strong><%= workspaceSummary.documents.length %></strong>
      <span>Meine Vorgaenge</span>
    </article>
  </div>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Meine Teams</h3>
      <span class="chip"><%= activeUser.displayName %></span>
    </div>
    <% if (workspaceSummary.groups.length === 0) { %>
      <div class="empty-state">
        <strong>Keine Teams sichtbar.</strong>
        <p>Der aktuelle User ist keinem sichtbaren Team zugeordnet.</p>
      </div>
    <% } else { %>
      <ul class="stack-list">
        <% workspaceSummary.groups.forEach((group) => { %>
          <li>
            <strong><%= group.name %></strong>
            <p><%= group.description ?? "Keine Beschreibung vorhanden." %></p>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Naechste Schritte</h3>
      <a class="text-link" href="/documents?user=<%= activeUser.key %>">Zu Einsaetzen</a>
    </div>
    <% if (workspaceSummary.tasks.length === 0) { %>
      <div class="empty-state">
        <strong>Keine offenen Schritte.</strong>
        <p>Im aktuellen Arbeitskontext gibt es keine persoenlichen Aufgaben.</p>
      </div>
    <% } else { %>
      <ul class="stack-list">
        <% workspaceSummary.tasks.forEach((task) => { %>
          <% const taskDocument = catalog.documents.find((document) => document.id === task.documentId); %>
          <% const taskTemplate = taskDocument ? catalog.templates.find((template) => template.id === taskDocument.templateId) : undefined; %>
          <li>
            <div class="action-row">
              <div>
                <strong><%= task.title %></strong>
                <p>
                  <%= taskDocument?.title ?? "Vorgang" %>
                  <% if (taskTemplate) { %>
                    · <%= taskTemplate.name %>
                  <% } %>
                </p>
                <p><%= task.action %> · Rolle: <%= task.role %> · Aktualisiert: <%= task.updatedAt %></p>
              </div>
              <% if (taskDocument) { %>
                <a class="button-secondary action-link" href="/documents/<%= task.documentId %>?user=<%= activeUser.key %>">Oeffnen</a>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Startbare Formulare</h3>
      <a class="text-link" href="/templates?user=<%= activeUser.key %>">Alle Templates</a>
    </div>
    <% if (workspaceSummary.templates.length === 0) { %>
      <div class="empty-state">
        <strong>Keine Templates sichtbar.</strong>
        <p>Es gibt aktuell keine produktiv nutzbaren Templates.</p>
      </div>
    <% } else { %>
      <% const sortedTemplates = [...workspaceSummary.templates].sort((left, right) => {
        if (left.status === "published" && right.status !== "published") return -1;
        if (left.status !== "published" && right.status === "published") return 1;
        return left.name.localeCompare(right.name);
      }); %>
      <ul class="stack-list compact">
        <% sortedTemplates.forEach((template) => { %>
          <li>
            <div class="action-row">
              <div>
                <strong><%= template.name %></strong>
                <p><%= template.description ?? template.key %></p>
                <p><span class="status-pill status-<%= template.status %>"><%= template.status %></span> · v<%= template.version %></p>
              </div>
              <% if (template.status === "published") { %>
                <form method="post" action="/documents/start?user=<%= activeUser.key %>" class="inline-form compact">
                  <input type="hidden" name="templateId" value="<%= template.id %>" />
                  <button class="button-secondary" type="submit">Starten</button>
                </form>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Meine Vorgaenge</h3>
      <a class="text-link" href="/documents?user=<%= activeUser.key %>">Zu Einsaetzen</a>
    </div>
    <% if (workspaceSummary.documents.length === 0) { %>
      <div class="empty-state">
        <strong>Keine relevanten Vorgaenge.</strong>
        <p>Es gibt keine sichtbaren, nicht archivierten Vorgaenge.</p>
      </div>
    <% } else { %>
      <ul class="stack-list compact">
        <% workspaceSummary.documents.forEach((document) => { %>
          <% const template = catalog.templates.find((item) => item.id === document.templateId); %>
          <li>
            <div class="action-row">
              <div>
                <strong><a class="text-link" href="/documents/<%= document.id %>?user=<%= activeUser.key %>"><%= document.title %></a></strong>
                <p><%= template?.name ?? "Unbekanntes Template" %></p>
                <p><span class="status-pill"><%= document.status %></span> · Aktualisiert: <%= document.updatedAt %></p>
              </div>
              <a class="button-secondary action-link" href="/documents/<%= document.id %>?user=<%= activeUser.key %>">Oeffnen</a>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>
</section>
