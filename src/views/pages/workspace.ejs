<section class="hero-card">
  <div>
    <h2><%= t("workspace.title") %></h2>
    <p><%= t("workspace.subtitle") %></p>
  </div>
  <div class="hero-metrics">
    <article>
      <strong><%= workspaceSummary.groups.length %></strong>
      <span>Teams</span>
    </article>
    <article>
      <strong><%= workspaceSummary.tasks.length %></strong>
      <span>Offene Schritte</span>
    </article>
    <article>
      <strong><%= workspaceSummary.documents.length %></strong>
      <span>Meine Vorgänge</span>
    </article>
  </div>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3>Meine Teams</h3>
      <span class="chip"><%= activeUser.displayName %></span>
    </div>
    <% if (workspaceSummary.groups.length === 0) { %>
      <div class="empty-state">
        <strong>Keine Teams sichtbar.</strong>
        <p>Der aktuelle User ist keinem sichtbaren Team zugeordnet.</p>
      </div>
    <% } else { %>
      <form method="post" action="<%= hrefWithContext('/preferences/primary-group') %>" class="stack-form">
        <ul class="stack-list">
          <li>
            <label class="filter-toggle">
              <input type="radio" name="groupId" value="" <%= !workspaceSummary.preferredGroupId ? "checked" : "" %> onchange="this.form.requestSubmit()" />
              <span>Keine primäre Gruppe</span>
            </label>
          </li>
        <% workspaceSummary.groups.forEach((group) => { %>
          <li>
            <label class="filter-toggle">
              <input type="radio" name="groupId" value="<%= group.id %>" <%= workspaceSummary.preferredGroupId === group.id ? "checked" : "" %> onchange="this.form.requestSubmit()" />
              <span><strong><%= group.name %></strong> · <%= group.description ?? "Keine Beschreibung vorhanden." %></span>
            </label>
          </li>
        <% }) %>
        </ul>
      </form>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3>Nächste Schritte</h3>
      <a class="text-link" href="<%= hrefWithContext('/documents') %>"><%= t("workspace.toDocuments") %></a>
    </div>
    <% if (workspaceSummary.tasks.length === 0) { %>
      <div class="empty-state">
        <strong>Keine offenen Schritte.</strong>
        <p>Im aktuellen Arbeitskontext gibt es keine persönlichen Aufgaben.</p>
      </div>
    <% } else { %>
      <ul class="stack-list">
        <% workspaceSummary.tasks.forEach((task) => { %>
          <% const taskDocument = catalog.documents.find((document) => document.id === task.documentId); %>
          <% const taskTemplate = taskDocument ? catalog.templates.find((template) => template.id === taskDocument.templateId) : undefined; %>
          <li>
            <div class="action-row">
              <div>
                <strong><%= task.title %></strong>
                <p>
                  <%= taskDocument?.title ?? "Vorgang" %>
                  <% if (taskTemplate) { %>
                    · <%= taskTemplate.name %>
                  <% } %>
                </p>
                <p><%= task.action %> · Rolle: <%= task.role %> · Aktualisiert: <%= task.updatedAt %></p>
              </div>
              <% if (taskDocument) { %>
                <a class="button-secondary action-link" href="<%= hrefWithContext(`/documents/${task.documentId}`) %>">Öffnen</a>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>
</section>

<section class="grid two-up">
  <article class="panel">
    <div class="panel-header">
      <h3><%= t("workspace.startableForms") %></h3>
      <a class="text-link" href="<%= hrefWithContext('/templates') %>"><%= t("workspace.allForms") %></a>
    </div>
    <% if (workspaceSummary.templates.length === 0) { %>
      <div class="empty-state">
        <strong>Keine Formulare sichtbar.</strong>
        <p>Es gibt aktuell keine produktiv nutzbaren Formulare.</p>
      </div>
    <% } else { %>
      <% const templatesByKey = new Map(); %>
      <% workspaceSummary.templates.forEach((template) => { %>
        <% const existing = templatesByKey.get(template.key) ?? []; %>
        <% existing.push(template); %>
        <% templatesByKey.set(template.key, existing); %>
      <% }) %>
      <% const sortedTemplates = Array.from(templatesByKey.entries()).map(([key, versions]) => {
        const orderedVersions = [...versions].sort((left, right) => right.version - left.version);
        const representative = orderedVersions.find((template) => template.status === "published") || orderedVersions.find((template) => template.status === "draft") || orderedVersions[0];
        return {
          key,
          representative,
          versions: orderedVersions,
          hasDraft: orderedVersions.some((template) => template.status === "draft"),
          hasPublished: orderedVersions.some((template) => template.status === "published"),
        };
      }).sort((left, right) => {
        if (left.representative.status === "published" && right.representative.status !== "published") return -1;
        if (left.representative.status !== "published" && right.representative.status === "published") return 1;
        return left.representative.name.localeCompare(right.representative.name);
      }); %>
      <ul class="stack-list compact">
        <% const preferredTemplateKey = workspaceSummary.preferredTemplateKey ?? ""; %>
        <% sortedTemplates.sort((left, right) => {
          if (left.key === preferredTemplateKey && right.key !== preferredTemplateKey) return -1;
          if (left.key !== preferredTemplateKey && right.key === preferredTemplateKey) return 1;
          return 0;
        }); %>
        <% sortedTemplates.forEach(({ representative, key, hasDraft, hasPublished }) => { %>
          <li>
            <div class="action-row">
              <div>
                <strong><%= representative.name %></strong>
                <p><%= representative.description ?? representative.key %></p>
                <p><span class="status-pill status-<%= representative.status %>"><%= representative.status %></span> · v<%= representative.version %><% if (hasDraft && representative.status === "published") { %> · Draft vorhanden<% } %><% if (preferredTemplateKey === key) { %> · <%= t("workspace.primaryForm") %><% } %></p>
              </div>
              <div class="inline-form compact">
                <form method="post" action="<%= hrefWithContext('/preferences/primary-template') %>" class="inline-form compact">
                  <label class="filter-toggle">
                    <input type="radio" name="templateKey" value="<%= key %>" <%= preferredTemplateKey === key ? "checked" : "" %> onchange="this.form.requestSubmit()" />
                    <span><%= t("workspace.primaryForm") %></span>
                  </label>
                </form>
                <% if (workspaceSummary.startableTemplateIds.includes(representative.id)) { %>
                  <form method="post" action="<%= hrefWithContext('/documents/start') %>" class="inline-form compact">
                    <input type="hidden" name="templateId" value="<%= representative.id %>" />
                    <button class="button-secondary" type="submit"><%= t("documents.start") %></button>
                  </form>
                <% } %>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h3><%= t("workspace.myDocuments") %></h3>
      <a class="text-link" href="<%= hrefWithContext('/documents') %>"><%= t("workspace.toDocuments") %></a>
    </div>
    <% if (workspaceSummary.documents.length === 0) { %>
      <div class="empty-state">
        <strong>Keine relevanten Vorgänge.</strong>
        <p>Es gibt keine sichtbaren, nicht archivierten Vorgänge.</p>
      </div>
    <% } else { %>
      <ul class="stack-list compact">
        <% workspaceSummary.documents.forEach((document) => { %>
          <% const template = catalog.templates.find((item) => item.id === document.templateId); %>
          <li>
            <div class="action-row">
              <div>
                <strong><a class="text-link" href="<%= hrefWithContext(`/documents/${document.id}`) %>"><%= document.title %></a></strong>
                <p><%= template?.name ?? "Unbekanntes Formular" %></p>
                <p><span class="status-pill"><%= document.status %></span> · Aktualisiert: <%= document.updatedAt %></p>
              </div>
              <a class="button-secondary action-link" href="<%= hrefWithContext(`/documents/${document.id}`) %>">Öffnen</a>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </article>
</section>
