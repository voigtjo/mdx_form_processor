<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2>Edit Group</h2>
    <p>Kleiner erster Edit-Pfad fuer bestehende MVP-Groups.</p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/admin/groups/<%= adminGroupEdit.group.id %>?user=<%= activeUser.key %>">Back to Group</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Edit Group</h3>
    <p class="panel-copy">Der Key bleibt in diesem ersten Schnitt stabil und read-only.</p>
  </div>
  <form method="post" action="/admin/groups/<%= adminGroupEdit.group.id %>/edit?user=<%= activeUser.key %>" class="form-stack">
    <div class="field-block">
      <label class="field-label" for="group-name">Name</label>
      <input id="group-name" name="name" type="text" value="<%= adminGroupEdit.group.name %>" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="group-key">Key</label>
      <input id="group-key" type="text" value="<%= adminGroupEdit.group.key %>" disabled />
    </div>
    <div class="field-block">
      <label class="field-label" for="group-description">Description</label>
      <textarea id="group-description" name="description" rows="4"><%= adminGroupEdit.group.description ?? "" %></textarea>
    </div>
    <div class="field-block">
      <label class="field-label" for="group-status">Status</label>
      <select id="group-status" name="status">
        <option value="active" <%= adminGroupEdit.group.status === "active" ? "selected" : "" %>>active</option>
        <option value="inactive" <%= adminGroupEdit.group.status === "inactive" ? "selected" : "" %>>inactive</option>
      </select>
    </div>
    <button class="button-primary" type="submit">Save Group</button>
  </form>
</section>
