<% const assignmentSummary = documentDetail.assignments.slice(0, 2).map((assignment) => { const user = users.find((entry) => entry.id === assignment.userId); return `${user?.displayName ?? assignment.userId} (${assignment.role})`; }).join(", "); %>
<% const activeAssignments = documentDetail.assignments.filter((assignment) => assignment.active); %>
<% const openTasks = documentDetail.tasks.filter((task) => task.status === "open"); %>
<% const leadTask = openTasks[0] ?? documentDetail.tasks[0]; %>
<% const activeApproverNamesForHeader = documentDetail.assignments
  .filter((assignment) => assignment.active && assignment.role === "approver")
  .map((assignment) => users.find((entry) => entry.id === assignment.userId)?.displayName ?? assignment.userId); %>
<% const workflowStepsForHeader = ["created", "submitted", "approved"]; %>
<% let nextStepLabel = "Kein weiterer direkter Schritt fuer den aktuellen User."; %>
<% if (documentDetail.submitState.isAvailable) { nextStepLabel = "Naechster Schritt: Submit"; } %>
<% if (documentDetail.approveState.isAvailable || documentDetail.rejectState.isAvailable) { nextStepLabel = "Naechster Schritt: Approve oder Reject"; } %>
<% if (!documentDetail.approveState.isAvailable && !documentDetail.rejectState.isAvailable && documentDetail.document.status === "submitted" && activeApproverNamesForHeader.length > 0) { nextStepLabel = `Naechster Schritt: Approve oder Reject durch ${activeApproverNamesForHeader.join(", ")}`; } %>
<% const latestAuditEvent = documentDetail.auditEvents[documentDetail.auditEvents.length - 1]; %>

<section id="document-header-fragment" data-fragment="document-header">
  <%- include("../partials/document-detail/document-header", {
    documentDetail,
    activeUser,
    users,
    assignmentSummary,
    activeAssignments,
    workflowStepsForHeader,
    nextStepLabel
  }) %>
</section>

<section id="document-context-fragment" data-fragment="document-context">
  <%- include("../partials/document-detail/document-context", {
    documentDetail,
    activeUser,
    users,
    assignmentSummary,
    activeAssignments,
    openTasks,
    leadTask
  }) %>
</section>

<% if (documentDetail.formRuntimeReference) { %>
  <section id="document-workspace-fragment" data-fragment="document-workspace">
    <%- include("../partials/document-detail/form-runtime-workspace", {
      documentDetail,
      activeUser,
      users,
      formRuntimeStatus,
      formRuntimeError,
      submitStatus,
      submitError,
      approveStatus,
      approveError,
      rejectStatus,
      rejectError,
      archiveStatus,
      archiveError
    }) %>
  </section>
<% } %>

<% if (documentDetail.templateFeatures.attachments.enabled) { %>
  <section id="document-attachments-fragment" data-fragment="document-attachments">
    <%- include("../partials/document-detail/attachments-panel", {
      documentDetail,
      activeUser,
      users,
      uploadStatus,
      uploadError
    }) %>
  </section>
<% } %>

<% if (!documentDetail.formRuntimeReference) { %>
  <section id="document-legacy-model-fragment" data-fragment="document-legacy-model">
    <%- include("../partials/document-detail/legacy-panel", {
      documentDetail,
      activeUser,
      saveStatus,
      saveError,
      submitStatus,
      submitError,
      approveStatus,
      approveError,
      rejectStatus,
      rejectError,
      archiveStatus,
      archiveError
    }) %>
  </section>
<% } %>

<% if (documentDetail.templateFeatures.journal.enabled) { %>
  <section id="document-journal-fragment" data-fragment="document-journal">
    <%- include("../partials/document-detail/journal-panel", {
      documentDetail,
      activeUser,
      journalStatus,
      journalError
    }) %>
  </section>
<% } %>

<section id="document-history-fragment" data-fragment="document-history">
  <%- include("../partials/document-detail/history-panel", {
    documentDetail,
    users,
    latestAuditEvent
  }) %>
</section>
