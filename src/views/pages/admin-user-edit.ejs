<section class="hero-card">
  <div>
    <span class="eyebrow">Admin-UI</span>
    <h2>Edit User</h2>
    <p>Kleiner erster Edit-Pfad für bestehende MVP-Users.</p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/admin/users/<%= adminUserEdit.user.id %>?user=<%= activeUser.key %>">Back to User</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Edit User</h3>
    <p class="panel-copy">Der Key bleibt in diesem ersten Schnitt stabil und schreibgeschützt.</p>
  </div>
  <form method="post" action="/admin/users/<%= adminUserEdit.user.id %>/edit?user=<%= activeUser.key %>" class="form-stack">
    <div class="field-block">
      <label class="field-label" for="user-display-name">Display Name</label>
      <input id="user-display-name" name="displayName" type="text" value="<%= adminUserEdit.user.displayName %>" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="user-key">Key</label>
      <input id="user-key" type="text" value="<%= adminUserEdit.user.key %>" disabled />
    </div>
    <div class="field-block">
      <label class="field-label" for="user-email">E-Mail</label>
      <input id="user-email" name="email" type="text" value="<%= adminUserEdit.user.email ?? "" %>" />
    </div>
    <div class="field-block">
      <label class="field-label" for="user-status">Status</label>
      <select id="user-status" name="status">
        <option value="active" <%= adminUserEdit.user.status === "active" ? "selected" : "" %>>active</option>
        <option value="inactive" <%= adminUserEdit.user.status === "inactive" ? "selected" : "" %>>inactive</option>
      </select>
    </div>
    <div class="field-block">
      <label class="field-label" for="user-locale"><%= t("admin.language") %></label>
      <select id="user-locale" name="locale">
        <option value="de" <%= adminUserEdit.user.locale === "de" ? "selected" : "" %>><%= t("language.de") %></option>
        <option value="en" <%= adminUserEdit.user.locale === "en" ? "selected" : "" %>><%= t("language.en") %></option>
      </select>
    </div>
    <button class="button-primary" type="submit">Save User</button>
  </form>
</section>
