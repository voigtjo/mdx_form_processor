<section class="hero-card">
  <div>
    <span class="eyebrow">Workflow Edit</span>
    <h2>New Workflow</h2>
    <p>Kleiner erster Neuanlage-Schnitt fuer ein Workflow-Draft. Ausfuehrliche Bearbeitung und Publizieren folgen in spaeteren Schritten.</p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/workflows?user=<%= activeUser.key %>">Back to Workflows</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Create Draft</h3>
    <p class="panel-copy">Der erste Schritt legt ein versioniertes Workflow-Draft mit einem kleinen JSON-Ausgangsstand an.</p>
  </div>
  <form method="post" action="/workflows/new?user=<%= activeUser.key %>" class="form-stack">
    <div class="field-block">
      <label class="field-label" for="workflow-name">Name</label>
      <input id="workflow-name" name="name" type="text" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="workflow-key">Key</label>
      <input id="workflow-key" name="key" type="text" required />
    </div>
    <div class="field-block">
      <label class="field-label" for="workflow-description">Beschreibung</label>
      <textarea id="workflow-description" name="description" rows="4"></textarea>
    </div>
    <button class="button-primary" type="submit">Create Draft</button>
  </form>
</section>
