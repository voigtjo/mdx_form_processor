<% if (templateDetail.formRuntimeReference) { %>
  <% const lifecycleLabel = templateDetail.template.status === "inactive" ? "unpublished" : templateDetail.template.status; %>
  <% const currentDraftVersion = templateDetail.versions.find((version) => version.status === "draft"); %>
  <% const currentPublishedVersion = templateDetail.versions.find((version) => version.status === "published"); %>
  <% const highestKnownVersion = templateDetail.versions.reduce((maxVersion, version) => Math.max(maxVersion, version.version), templateDetail.template.version); %>
  <% const nextDraftVersion = currentDraftVersion ? currentDraftVersion.version : highestKnownVersion + 1; %>
  <% const publishTargetVersion = templateDetail.template.status === "draft" ? templateDetail.template.version : nextDraftVersion; %>
  <% const viewedVersion = templateDetail.template.version; %>
  <details class="panel panel-collapsible page-header-collapsible">
    <summary class="collapsible-summary">
      <div class="collapsible-summary-copy">
        <strong><%= templateDetail.template.name %></strong>
        <span><%= templateDetail.template.name %> v<%= templateDetail.template.version %> · <%= templateDetail.template.formType %> · <%= lifecycleLabel %></span>
      </div>
      <div class="collapsible-summary-meta">
        <span>Template</span>
        <span>v<%= viewedVersion %></span>
      </div>
    </summary>
    <div class="collapsible-body">
      <span class="eyebrow">Template</span>
      <h2><%= templateDetail.template.name %></h2>
      <p class="hero-inline-meta"><strong>Formular:</strong> v<%= templateDetail.template.version %> · <strong>Typ:</strong> <%= templateDetail.template.formType %> · <strong>Workflow:</strong> <%= templateDetail.workflow?.name ?? "Nicht zugeordnet" %><% if (templateDetail.workflow) { %> v<%= templateDetail.workflow.version %><% } %></p>
      <p class="hero-inline-meta"><strong>Status:</strong> <%= lifecycleLabel %> · <strong>Key:</strong> <%= templateDetail.template.key %> · <strong>Updated:</strong> <%= templateDetail.template.updatedAt %></p>
      <p class="hero-inline-meta"><strong>Draft:</strong> <%= currentDraftVersion ? `v${currentDraftVersion.version}` : `naechster Draft v${nextDraftVersion}` %> · <strong>Published:</strong> <%= currentPublishedVersion ? `v${currentPublishedVersion.version}` : "keine" %></p>
      <div class="hero-actions">
        <a class="button-secondary" href="/templates?user=<%= activeUser.key %>">Back to Templates</a>
      </div>
    </div>
  </details>

  <details class="panel panel-collapsible">
    <summary class="collapsible-summary">
      <div class="collapsible-summary-copy">
        <strong>Context</strong>
        <span><%= templateDetail.workflow?.name ?? "Kein Workflow" %><% if (templateDetail.workflow) { %> v<%= templateDetail.workflow.version %><% } %> · <%= templateDetail.assignmentsWithGroups.length %> Groups · <%= templateDetail.relatedDocuments.length %> Documents</span>
      </div>
      <div class="collapsible-summary-meta">
        <span><%= templateDetail.versions.length %> Versionen</span>
      </div>
    </summary>
    <div class="collapsible-body">
      <div class="grid two-up detail-grid">
        <div>
          <p><strong>Workflow</strong><br /><%= templateDetail.workflow?.name ?? "Nicht zugeordnet" %><% if (templateDetail.workflow) { %> v<%= templateDetail.workflow.version %><% } %></p>
          <p><strong>Form Type</strong><br /><%= templateDetail.template.formType %></p>
          <p><strong>Groups</strong><br /><%= templateDetail.assignmentsWithGroups.length > 0 ? templateDetail.assignmentsWithGroups.map(({ group, assignment }) => group?.name ?? assignment.groupId).join(", ") : "keine" %></p>
          <p><strong>Beschreibung</strong><br /><%= templateDetail.template.description ?? "Keine Beschreibung hinterlegt." %></p>
        </div>
        <div>
          <h4>Versions</h4>
          <ul class="stack-list compact">
            <% templateDetail.versions.forEach((version) => { %>
              <% const versionLifecycleLabel = version.status === "inactive" ? "unpublished" : version.status; %>
              <li class="action-row">
                <div>
                  <strong>v<%= version.version %></strong>
                  <p><%= versionLifecycleLabel %></p>
                </div>
                <% if (version.id === templateDetail.template.id) { %>
                  <span class="chip">Current</span>
                <% } else { %>
                  <a class="text-link action-link" href="/templates/<%= version.id %>?user=<%= activeUser.key %>">Open</a>
                <% } %>
              </li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </details>

  <section class="panel">
    <div class="panel-header">
      <h3>Template Source</h3>
      <span><%= lifecycleLabel %> · v<%= templateDetail.template.version %></span>
    </div>

    <form method="post" action="/templates/<%= templateDetail.template.id %>/source?user=<%= activeUser.key %>" class="stack-list">
      <article class="subpanel">
        <div class="panel-header">
          <h4>Lifecycle</h4>
        </div>
        <div class="field-block">
          <label class="field-label" for="template-workflow-version">Workflow-Version</label>
          <select id="template-workflow-version" name="workflowTemplateId" class="text-input">
            <% templateDetail.availableWorkflows.forEach((workflowVersion) => { %>
              <option value="<%= workflowVersion.id %>" <%= workflowVersion.id === templateDetail.selectedWorkflowTemplateId ? "selected" : "" %>>
                <%= workflowVersion.name %> · <%= workflowVersion.key %> · v<%= workflowVersion.version %> · <%= workflowVersion.status === "inactive" ? "unpublished" : workflowVersion.status %>
              </option>
            <% }) %>
          </select>
          <% if (templateDetail.workflowPublishBlockedReason) { %>
            <p class="field-help"><%= templateDetail.workflowPublishBlockedReason %></p>
          <% } %>
          <label class="checkbox-item">
            <input type="checkbox" name="cascadePublishWorkflow" />
            <span>Cascade Publish Workflow</span>
          </label>
        </div>
        <div class="template-lifecycle-actions">
          <button class="button-secondary" type="submit" name="intent" value="save_draft">
            Save Draft v<%= nextDraftVersion %>
          </button>
          <button class="button-primary" type="submit" name="intent" value="publish">
            Publish v<%= publishTargetVersion %>
          </button>
          <button
            class="button-secondary"
            type="submit"
            name="intent"
            value="unpublish"
            <%= templateDetail.template.status === "published" ? "" : "disabled" %>>
            Unpublish v<%= viewedVersion %>
          </button>
          <button
            class="button-secondary"
            type="submit"
            name="intent"
            value="archive"
            <%= templateDetail.template.status === "inactive" ? "" : "disabled" %>>
            Archive v<%= viewedVersion %>
          </button>
        </div>
      </article>

      <article class="subpanel">
        <div class="panel-header">
          <h4>Source</h4>
        </div>
        <textarea name="source" rows="22" class="form-runtime-source-editor"><%= templateDetail.formRuntimeReference.sourceText %></textarea>
      </article>

      <% if (templateDetail.formRuntimeReference.apiBindings && templateDetail.formRuntimeReference.apiBindings.length > 0) { %>
        <article class="subpanel">
          <div class="panel-header">
            <h4>API Operations</h4>
          </div>
          <div class="stack-list compact">
            <% templateDetail.formRuntimeReference.apiBindings.forEach((binding) => { %>
              <div class="field-block">
                <label class="field-label" for="api-binding-<%= binding.actionName %>"><%= binding.label %></label>
                <select id="api-binding-<%= binding.actionName %>" name="apiBinding.<%= binding.actionName %>" class="text-input">
                  <option value="">Keine Operation zugeordnet</option>
                  <% templateDetail.availableOperations.forEach((operation) => { %>
                    <option value="<%= operation.key %>" <%= operation.key === binding.operationRef ? "selected" : "" %>>
                      <%= operation.key %> · <%= operation.title %> · <%= operation.status %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% }) %>
          </div>
        </article>
      <% } %>

      <article class="subpanel">
        <h4>Kopfdaten</h4>
        <div class="grid two-up detail-grid">
          <p><strong>form_type</strong><br /><%= templateDetail.template.formType %></p>
          <p><strong>attachments_enabled</strong><br /><%= templateDetail.templateFeatures.attachments.enabled ? "Ja" : "Nein" %></p>
          <p><strong>journal_enabled</strong><br /><%= templateDetail.templateFeatures.journal.enabled ? "Ja" : "Nein" %></p>
        </div>
      </article>
    </form>

    <% if (templateDetail.formRuntimeReference.parseError) { %>
      <div class="notice-card notice-error">
        <strong>Source aktuell nicht lesbar</strong>
        <p><%= templateDetail.formRuntimeReference.parseError %></p>
      </div>
    <% } else if (templateDetail.formRuntimeReference.parsedForm) { %>
      <article class="subpanel">
        <div class="panel-header">
          <h4>Form Layout</h4>
        </div>
        <div class="form-runtime-readonly-stack">
          <% templateDetail.formRuntimeReference.parsedForm.sections.forEach((section) => { %>
            <article class="subpanel form-runtime-readonly-section">
              <div class="panel-header">
                <h4><%= section.title %></h4>
              </div>

              <% section.rows.forEach((row) => { %>
                <div class="form-runtime-readonly-row form-runtime-columns-<%= Math.min(row.slots.length, 3) %>">
                  <% row.slots.forEach((slot) => { %>
                    <% const element = slot.element; %>
                    <% if (element.kind === "field") { %>
                      <article class="field-block form-runtime-readonly-field form-runtime-type-<%= element.controlType %>">
                        <label class="field-label"><%= element.label ?? element.name %><% if (element.properties.required === true) { %><span class="field-required" aria-hidden="true">*</span><span class="sr-only"> Pflichtfeld</span><% } %></label>
                        <% if (element.controlType === "grid" && typeof element.properties.columns === "string") { %>
                          <% const gridColumns = element.properties.columns.split("|").map((column) => column.trim()).filter((column) => column.length > 0).map((column) => {
                            const [namePart, labelPart] = column.split(":");
                            return {
                              name: (namePart ?? "").trim(),
                              label: (labelPart ?? namePart ?? "").trim() || (namePart ?? "").trim(),
                            };
                          }).filter((column) => column.name.length > 0); %>
                          <div class="table-wrap">
                            <table class="form-runtime-grid-table is-readonly">
                              <thead>
                                <tr>
                                  <% gridColumns.forEach((column) => { %>
                                    <th><%= column.label %></th>
                                  <% }) %>
                                </tr>
                              </thead>
                              <tbody>
                                <tr>
                                  <% gridColumns.forEach(() => { %>
                                    <td>—</td>
                                  <% }) %>
                                </tr>
                              </tbody>
                            </table>
                          </div>
                        <% } else if (element.controlType === "textarea") { %>
                          <div class="form-runtime-value form-runtime-value-textarea">Noch kein Wert</div>
                        <% } else if (element.controlType === "select") { %>
                          <div class="form-runtime-value">Noch keine Auswahl</div>
                        <% } else if (element.controlType === "signature") { %>
                          <div class="form-runtime-signature-card">
                            <strong>Noch nicht signiert</strong>
                          </div>
                        <% } else { %>
                          <div class="form-runtime-value">Noch kein Wert</div>
                        <% } %>
                      </article>
                    <% } else { %>
                      <article class="field-block form-runtime-readonly-field form-runtime-action-card form-runtime-type-<%= element.controlType %>">
                        <label class="field-label"><%= element.label ?? element.name %></label>
                        <div class="form-runtime-action-button" aria-disabled="true"><%= element.label ?? element.name %></div>
                      </article>
                    <% } %>
                  <% }) %>
                </div>
              <% }) %>
            </article>
          <% }) %>
        </div>
      </article>
    <% } %>
  </section>
<% } else { %>
  <section class="hero-card">
    <div>
      <span class="eyebrow">Template Detail</span>
      <h2><%= templateDetail.template.name %></h2>
      <p>Review-Sicht fuer ein einzelnes Form Template mit Form-, Workflow-, Integrations-, Versions- und Documents-Kontext.</p>
    </div>
    <div class="hero-actions">
      <a class="button-secondary" href="/templates?user=<%= activeUser.key %>">Back to Templates</a>
    </div>
  </section>

  <section class="grid two-up">
    <article class="panel">
      <div class="panel-header">
        <h3>Overview</h3>
        <span class="chip">v<%= templateDetail.template.version %></span>
      </div>
      <p><strong>Key:</strong> <%= templateDetail.template.key %></p>
      <p><strong>Status:</strong> <span class="status-pill status-<%= templateDetail.template.status %>"><%= templateDetail.template.status %></span></p>
      <p><strong>Updated:</strong> <%= templateDetail.template.updatedAt %></p>
      <p><%= templateDetail.template.description ?? "Keine Beschreibung hinterlegt." %></p>
      <p><strong>Template Keys:</strong> <%= templateDetail.template.templateKeys.length > 0 ? templateDetail.template.templateKeys.join(", ") : "keine" %></p>
      <p><strong>Document Keys:</strong> <%= templateDetail.template.documentKeys.length > 0 ? templateDetail.template.documentKeys.join(", ") : "keine" %></p>
      <p><strong>Table Fields:</strong> <%= templateDetail.template.tableFields.length > 0 ? templateDetail.template.tableFields.join(", ") : "keine" %></p>
    </article>

    <article class="panel">
      <div class="panel-header">
        <h3>Workflow</h3>
        <% if (templateDetail.workflow) { %>
          <a class="text-link" href="/workflows/<%= templateDetail.workflow.id %>?user=<%= activeUser.key %>">Open Workflow</a>
        <% } %>
      </div>
      <% if (templateDetail.workflow) { %>
        <p><strong>Name:</strong> <%= templateDetail.workflow.name %></p>
        <p><strong>Key:</strong> <%= templateDetail.workflow.key %></p>
        <p><strong>Version:</strong> v<%= templateDetail.workflow.version %></p>
        <p><strong>Statusfolge:</strong> <%= templateDetail.workflow.statuses.join(" → ") %></p>
        <ul class="stack-list compact">
          <% templateDetail.workflow.actions.forEach((action) => { %>
            <li>
              <strong><%= action.name %></strong>
              <p><%= action.from.join(", ") %> → <%= action.to %> · Rollen: <%= action.allowedRoles.join(", ") %></p>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <div class="empty-state">
          <strong>Kein Workflow sichtbar.</strong>
          <p>Dem Template ist im aktuellen Sichtkontext kein Workflow zugeordnet.</p>
        </div>
      <% } %>
    </article>
  </section>

  <section class="grid two-up">
    <article class="panel">
      <h3>Assignments</h3>
      <p class="panel-copy">Group-Sichtbarkeit dieses Templates. Pflege im ersten Schnitt ueber die jeweilige Group-Detailseite.</p>
      <% if (templateDetail.assignmentsWithGroups.length === 0) { %>
        <div class="empty-state">
          <strong>Keine Group-Zuordnungen.</strong>
          <p>Dieses Template ist aktuell keiner sichtbaren Group zugeordnet.</p>
        </div>
      <% } else { %>
        <ul class="stack-list compact">
          <% templateDetail.assignmentsWithGroups.forEach(({ assignment, group }) => { %>
            <li>
              <strong>
                <% if (group) { %>
                  <a class="text-link" href="/admin/groups/<%= group.id %>?user=<%= activeUser.key %>"><%= group.name %></a>
                <% } else { %>
                  <%= assignment.groupId %>
                <% } %>
              </strong>
              <p>
                <%= group?.key ?? assignment.groupId %>
                · <%= assignment.status %>
                · assigned <%= assignment.assignedAt %>
              </p>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </article>

    <article class="panel">
      <div class="panel-header">
        <h3>Documents</h3>
        <a class="text-link" href="/documents?user=<%= activeUser.key %>&q=<%= encodeURIComponent(templateDetail.template.key) %>">Open Documents</a>
      </div>
      <% if (templateDetail.relatedDocuments.length === 0) { %>
        <div class="empty-state">
          <strong>Keine sichtbaren Documents.</strong>
          <p>Im aktuellen Sichtkontext wurden zu diesem Template noch keine sichtbaren Documents gefunden.</p>
        </div>
      <% } else { %>
        <ul class="stack-list compact">
          <% templateDetail.relatedDocuments.forEach((document) => { %>
            <li class="action-row">
              <div>
                <strong><%= document.title %></strong>
                <p>Status: <%= document.status %> · Updated: <%= document.updatedAt %></p>
              </div>
              <a class="text-link action-link" href="/documents/<%= document.id %>?user=<%= activeUser.key %>">Open</a>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </article>
  </section>

  <section class="panel">
    <h3>Alt Model (MDX)</h3>
    <p class="panel-copy">Bestehender Produktstand des Templates im bisherigen MDX-/Formmodell.</p>
    <div class="grid two-up detail-grid">
      <article class="subpanel">
        <h4>Sections</h4>
        <% if (templateDetail.formDefinition.sections.length === 0) { %>
          <p>Keine Sections erkannt.</p>
        <% } else { %>
          <ul class="stack-list compact">
            <% templateDetail.formDefinition.sections.forEach((section) => { %>
              <li><strong><%= section %></strong></li>
            <% }) %>
          </ul>
        <% } %>
      </article>
      <article class="subpanel">
        <h4>Fields</h4>
        <% if (templateDetail.formDefinition.fields.length === 0) { %>
          <p>Keine Fields erkannt.</p>
        <% } else { %>
          <ul class="stack-list compact">
            <% templateDetail.formDefinition.fields.forEach((field) => { %>
              <li>
                <strong><%= field.label %></strong>
                <p><%= field.name %> · <%= field.type %></p>
                <p><%= field.flags.length > 0 ? field.flags.join(", ") : "keine Flags" %></p>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </article>
    </div>
    <div class="panel-divider"></div>
    <h4>MDX Source</h4>
    <pre class="code-block"><%= templateDetail.template.mdxBody %></pre>
  </section>

  <section class="grid two-up">
    <article class="panel">
      <h3>Integrations</h3>
      <% if (templateDetail.integrations.actions.length === 0 && templateDetail.integrations.fields.length === 0) { %>
        <div class="empty-state">
          <strong>Keine Integrationsbezüge erkannt.</strong>
          <p>Im aktuellen Template wurden keine API-Referenzen erkannt.</p>
        </div>
      <% } else { %>
        <ul class="stack-list compact">
          <% templateDetail.integrations.fields.forEach((field) => { %>
            <li>
              <strong>Field: <%= field.label %></strong>
              <p><%= field.operationRef %></p>
            </li>
          <% }) %>
          <% templateDetail.integrations.actions.forEach((action) => { %>
            <li>
              <strong>Action: <%= action.label ?? action.name %></strong>
              <p><%= action.operationRef %></p>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </article>

    <article class="panel">
      <h3>Versions</h3>
      <ul class="stack-list compact">
        <% templateDetail.versions.forEach((version) => { %>
          <li class="action-row">
            <div>
              <strong>v<%= version.version %></strong>
              <p><%= version.status %></p>
            </div>
            <% if (version.id === templateDetail.template.id) { %>
              <span class="chip">Current</span>
            <% } else { %>
              <a class="text-link action-link" href="/templates/<%= version.id %>?user=<%= activeUser.key %>">Open</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </article>
  </section>
<% } %>
