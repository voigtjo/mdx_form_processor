<% const viewedVersion = workflowDetail.workflow.version; %>
<% const editableRows = workflowDetail.transitionRows.concat([
  { actionName: "", from: [], to: "", roles: [], rolesLabel: "", modeLabel: "OR", apiLabel: "", conditionLabel: "" },
  { actionName: "", from: [], to: "", roles: [], rolesLabel: "", modeLabel: "OR", apiLabel: "", conditionLabel: "" },
]); %>

<details class="panel panel-collapsible page-header-collapsible">
  <summary class="collapsible-summary">
    <div class="collapsible-summary-copy">
      <strong><%= workflowDetail.workflow.name %></strong>
      <span><%= workflowDetail.workflow.name %> v<%= workflowDetail.workflow.version %> · <%= workflowDetail.lifecycleLabel %> · <%= workflowDetail.workflow.statuses.length %> Status</span>
    </div>
    <div class="collapsible-summary-meta">
      <span>Workflow</span>
      <span>v<%= viewedVersion %></span>
    </div>
  </summary>
  <div class="collapsible-body">
    <span class="eyebrow">Workflow</span>
    <h2><%= workflowDetail.workflow.name %></h2>
    <p class="hero-inline-meta"><strong>Key:</strong> <%= workflowDetail.workflow.key %> · <strong>Status:</strong> <%= workflowDetail.lifecycleLabel %> · <strong>Initial:</strong> <%= workflowDetail.workflow.initialStatus %></p>
    <p class="hero-inline-meta"><strong>Draft:</strong> <%= workflowDetail.currentDraftVersion ? `v${workflowDetail.currentDraftVersion.version}` : `naechster Draft v${workflowDetail.nextDraftVersion}` %> · <strong>Published:</strong> <%= workflowDetail.currentPublishedVersion ? `v${workflowDetail.currentPublishedVersion.version}` : "keine" %> · <strong>Updated:</strong> <%= workflowDetail.workflow.updatedAt %></p>
    <div class="hero-actions">
      <a class="button-secondary" href="/workflows?user=<%= activeUser.key %>">Back to Workflows</a>
    </div>
  </div>
</details>

<details class="panel panel-collapsible">
  <summary class="collapsible-summary">
    <div class="collapsible-summary-copy">
      <strong>Context</strong>
      <span><%= workflowDetail.transitionRows.length %> Actions · <%= workflowDetail.relatedTemplates.length %> Templates · <%= workflowDetail.relatedDocuments.length %> Documents</span>
    </div>
    <div class="collapsible-summary-meta">
      <span><%= workflowDetail.versions.length %> Versionen</span>
    </div>
  </summary>
  <div class="collapsible-body">
    <div class="grid two-up detail-grid">
      <div>
        <p><strong>Beschreibung</strong><br /><%= workflowDetail.workflow.description ?? "Keine Beschreibung hinterlegt." %></p>
        <p><strong>Statusfolge</strong><br /><%= workflowDetail.sourceStatuses.join(" → ") %></p>
        <p><strong>Templates</strong><br /><%= workflowDetail.relatedTemplates.length > 0 ? workflowDetail.relatedTemplates.map((template) => `${template.name} v${template.version}`).join(", ") : "keine sichtbaren Templates" %></p>
      </div>
      <div>
        <h4>Versionen</h4>
        <ul class="stack-list compact">
          <% workflowDetail.versions.forEach((version) => { %>
            <% const versionLifecycleLabel = version.status === "inactive" ? "unpublished" : version.status; %>
            <li class="action-row">
              <div>
                <strong>v<%= version.version %></strong>
                <p><%= versionLifecycleLabel %></p>
              </div>
              <% if (version.id === workflowDetail.workflow.id) { %>
                <span class="chip">Current</span>
              <% } else { %>
                <a class="text-link action-link" href="/workflows/<%= version.id %>?user=<%= activeUser.key %>">Open</a>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</details>

<section class="panel">
  <div class="panel-header">
    <h3>Workflow Table</h3>
    <div class="panel-header-actions">
      <span class="chip"><%= workflowDetail.transitionRows.length %> Actions</span>
      <button class="button-secondary" type="button" data-modal-open="workflow-json-dialog">JSON</button>
    </div>
  </div>

  <form method="post" action="/workflows/<%= workflowDetail.workflow.id %>/source?user=<%= activeUser.key %>" class="stack-list">
    <textarea class="sr-only" name="source"><%= workflowDetail.workflowSourceText %></textarea>
    <article class="subpanel">
      <div class="panel-header">
        <h4>Lifecycle</h4>
        <span class="chip">Versionen</span>
      </div>
      <p class="panel-copy lifecycle-copy">
        Betrachtet: v<%= viewedVersion %> ·
        Draft in Arbeit: <%= workflowDetail.currentDraftVersion ? `v${workflowDetail.currentDraftVersion.version}` : "noch keiner" %> ·
        Published: <%= workflowDetail.currentPublishedVersion ? `v${workflowDetail.currentPublishedVersion.version}` : "keine" %>
      </p>
      <div class="template-lifecycle-actions">
        <button class="button-secondary" type="submit" name="intent" value="save_draft">
          Save Draft v<%= workflowDetail.nextDraftVersion %>
        </button>
        <button class="button-primary" type="submit" name="intent" value="publish">
          Publish v<%= workflowDetail.publishTargetVersion %>
        </button>
        <button
          class="button-secondary"
          type="submit"
          name="intent"
          value="unpublish"
          <%= workflowDetail.canUnpublish ? "" : "disabled" %>>
          Unpublish v<%= viewedVersion %>
        </button>
        <button
          class="button-secondary"
          type="submit"
          name="intent"
          value="archive"
          <%= workflowDetail.canArchive ? "" : "disabled" %>>
          Archive v<%= viewedVersion %>
        </button>
      </div>
      <% if (workflowDetail.unpublishBlockedReason) { %>
        <p class="field-help"><%= workflowDetail.unpublishBlockedReason %></p>
      <% } %>
      <% if (workflowDetail.archiveBlockedReason) { %>
        <p class="field-help"><%= workflowDetail.archiveBlockedReason %></p>
      <% } %>
    </article>

    <% if (workflowDetail.sourceError) { %>
      <div class="notice-card notice-error notice-inline">
        <strong>Workflow Source nicht lesbar</strong>
        <p><%= workflowDetail.sourceError %></p>
      </div>
    <% } %>

    <article class="subpanel">
      <div class="workflow-table-meta">
        <div class="field-block">
          <label class="field-label" for="workflow-initial-status">Initialstatus</label>
          <input id="workflow-initial-status" class="text-input" type="text" name="initialStatus" value="<%= workflowDetail.workflow.initialStatus %>" />
        </div>
        <div class="field-block">
          <label class="field-label" for="workflow-statuses-text">Statusfolge</label>
          <input id="workflow-statuses-text" class="text-input" type="text" name="statusesText" value="<%= workflowDetail.sourceStatuses.join(', ') %>" />
        </div>
      </div>

      <div class="table-wrap">
        <table class="workflow-transition-table workflow-transition-editor-table">
          <thead>
            <tr>
              <th>Action</th>
              <th>From</th>
              <th>To</th>
              <th>Roles</th>
              <th>Mode</th>
              <th>API</th>
              <th>Condition</th>
            </tr>
          </thead>
          <tbody>
            <% editableRows.forEach((row, index) => { %>
              <tr>
                <td><input class="text-input" type="text" name="actionName__<%= index %>" value="<%= row.actionName %>" placeholder="submit" /></td>
                <td><input class="text-input" type="text" name="actionFrom__<%= index %>" value="<%= row.from.join(', ') %>" placeholder="created, started" /></td>
                <td><input class="text-input" type="text" name="actionTo__<%= index %>" value="<%= row.to %>" placeholder="submitted" /></td>
                <td><input class="text-input" type="text" name="actionRoles__<%= index %>" value="<%= row.roles.join(', ') %>" placeholder="editor, approver" /></td>
                <td>
                  <select class="text-input" name="actionMode__<%= index %>">
                    <option value="OR" <%= row.modeLabel === "OR" ? "selected" : "" %>>OR</option>
                    <option value="AND" <%= row.modeLabel === "AND" ? "selected" : "" %>>AND</option>
                  </select>
                </td>
                <td><input class="text-input" type="text" name="actionApi__<%= index %>" value="<%= row.apiLabel === '—' ? '' : row.apiLabel %>" list="workflow-api-options" placeholder="customers.lookup" /></td>
                <td><input class="text-input" type="text" name="actionCondition__<%= index %>" value="<%= row.conditionLabel === '—' ? '' : row.conditionLabel %>" placeholder='requiredFields: customer_id' /></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <datalist id="workflow-api-options">
        <% workflowDetail.availableOperations.forEach((operation) => { %>
          <option value="<%= operation.key %>"><%= operation.title %></option>
        <% }) %>
      </datalist>
    </article>
  </form>
</section>

<dialog id="workflow-json-dialog" class="workflow-json-dialog">
  <div class="workflow-json-dialog-card">
    <div class="panel-header">
      <h4>Workflow JSON</h4>
      <button class="button-secondary" type="button" data-modal-close>Schliessen</button>
    </div>
    <form method="post" action="/workflows/<%= workflowDetail.workflow.id %>/source?user=<%= activeUser.key %>" class="stack-list">
      <input type="hidden" name="sourceMode" value="json" />
      <textarea name="source" rows="24" class="form-runtime-source-editor"><%= workflowDetail.workflowSourceText %></textarea>
      <div class="template-lifecycle-actions">
        <button class="button-secondary" type="submit" name="intent" value="save_draft">Save Draft v<%= workflowDetail.nextDraftVersion %></button>
        <button class="button-primary" type="submit" name="intent" value="publish">Publish v<%= workflowDetail.publishTargetVersion %></button>
      </div>
    </form>
  </div>
</dialog>
