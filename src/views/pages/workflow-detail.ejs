<% const viewedVersion = workflowDetail.workflow.version; %>
<% const editableRows = workflowDetail.transitionRows.concat([
  { actionName: "", from: [], to: "", roles: [], rolesLabel: "", modeLabel: "OR", apiLabel: "", conditionLabel: "" },
  { actionName: "", from: [], to: "", roles: [], rolesLabel: "", modeLabel: "OR", apiLabel: "", conditionLabel: "" },
]); %>
<% const isEditable = workflowDetail.isEditable; %>

<section class="hero-card hero-card-compact workflow-detail-hero">
  <div>
    <strong><%= workflowDetail.workflow.name %></strong>
    <p class="hero-inline-meta"><%= workflowDetail.workflow.key %> · v<%= viewedVersion %> · <%= workflowDetail.lifecycleLabel %></p>
    <% if (workflowDetail.workflow.description) { %>
      <p class="hero-copy compact"><%= workflowDetail.workflow.description %></p>
    <% } %>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="<%= hrefWithContext('/workflows') %>">Back to Workflows</a>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Workflow Definition</h3>
    <div class="panel-header-actions">
      <span class="chip"><%= workflowDetail.transitionRows.length %> Actions</span>
      <button
        class="button-secondary"
        type="button"
        data-modal-open="workflow-json-dialog"
        onclick="document.getElementById('workflow-json-dialog')?.showModal()"
      >JSON</button>
    </div>
  </div>

  <article class="subpanel">
    <div class="panel-header">
      <h4>Versionen</h4>
      <div class="panel-header-actions">
        <% if (workflowDetail.canStartEdit) { %>
          <form method="post" action="<%= hrefWithContext(`/workflows/${workflowDetail.workflow.id}/edit`, { version: workflowDetail.selectedVersionId }) %>" class="inline-form compact">
            <button class="button-primary" type="submit"><%= workflowDetail.isEditMode ? "Entwurf bearbeiten" : "Bearbeiten" %></button>
          </form>
        <% } %>
      </div>
    </div>
    <div class="compact-meta-block">
      <p><strong>Aktuelle Ansicht:</strong> v<%= workflowDetail.workflow.version %> · <%= workflowDetail.lifecycleLabel %> <% if (workflowDetail.isEditMode) { %>· Edit-Modus<% } %></p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Version</th>
            <th>Status</th>
            <th>Ansicht</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <% workflowDetail.versions.forEach((version) => { %>
            <% const isCurrentVersion = version.id === workflowDetail.selectedVersionId; %>
            <% const versionLifecycleLabel = version.status === "inactive" ? "unpublished" : version.status; %>
            <tr>
              <td><strong>v<%= version.version %></strong></td>
              <td><span class="status-pill status-<%= version.status %>"><%= versionLifecycleLabel %></span></td>
              <td><%= isCurrentVersion ? "Aktuell" : "Readonly" %></td>
              <td><a class="text-link" href="<%= hrefWithContext(`/workflows/${version.id}`, { version: version.id }) %>">Anzeigen</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <form method="post" action="<%= hrefWithContext(`/workflows/${workflowDetail.workflow.id}/source`) %>" class="stack-list">
    <textarea class="sr-only" name="source"><%= workflowDetail.workflowSourceText %></textarea>
    <article class="subpanel">
      <div class="template-lifecycle-actions">
        <button class="button-secondary" type="submit" name="intent" value="save_draft" <%= isEditable ? "" : "disabled" %>>
          Save Draft v<%= workflowDetail.nextDraftVersion %>
        </button>
        <button class="button-primary" type="submit" name="intent" value="publish" <%= isEditable && workflowDetail.canPublishVersion ? "" : "disabled" %>>
          Publish v<%= workflowDetail.publishTargetVersion %>
        </button>
        <button
          class="button-secondary"
          type="submit"
          name="intent"
          value="unpublish"
          <%= isEditable && workflowDetail.canUnpublish ? "" : "disabled" %>>
          Unpublish v<%= viewedVersion %>
        </button>
        <button
          class="button-secondary"
          type="submit"
          name="intent"
          value="archive"
          <%= isEditable && workflowDetail.canArchive ? "" : "disabled" %>>
          Archive v<%= viewedVersion %>
        </button>
      </div>
    </article>

      <% if (workflowDetail.sourceError) { %>
      <div class="notice-card notice-error notice-inline">
        <strong>Workflow Source nicht lesbar</strong>
        <p><%= workflowDetail.sourceError %></p>
      </div>
    <% } %>

    <article class="subpanel">
      <div class="workflow-table-meta">
        <div class="field-block">
          <label class="field-label" for="workflow-statuses-text">Statusfolge</label>
          <input id="workflow-statuses-text" class="text-input" type="hidden" name="statusesText" value="<%= workflowDetail.sourceStatuses.join(', ') %>" />
          <div class="workflow-status-editor" data-workflow-status-editor>
            <div class="stack-list compact" data-workflow-status-list>
              <% workflowDetail.statusEditorRows.forEach((statusValue, index) => { %>
                <div class="action-row" data-workflow-status-row>
                  <input class="text-input" type="text" name="statusValue__<%= index %>" value="<%= statusValue %>" placeholder="Status" <%= isEditable ? "" : "readonly" %> />
                  <div class="panel-header-actions">
                    <button class="button-secondary" type="button" data-workflow-status-move="up" <%= isEditable ? "" : "disabled" %>>Hoch</button>
                    <button class="button-secondary" type="button" data-workflow-status-move="down" <%= isEditable ? "" : "disabled" %>>Runter</button>
                    <button class="button-secondary" type="button" data-workflow-status-remove <%= isEditable ? "" : "disabled" %>>Loeschen</button>
                  </div>
                </div>
              <% }) %>
            </div>
            <template data-workflow-status-template>
              <div class="action-row" data-workflow-status-row>
                <input class="text-input" type="text" name="statusValue__INDEX__" value="" placeholder="Status" />
                <div class="panel-header-actions">
                  <button class="button-secondary" type="button" data-workflow-status-move="up" <%= isEditable ? "" : "disabled" %>>Hoch</button>
                  <button class="button-secondary" type="button" data-workflow-status-move="down" <%= isEditable ? "" : "disabled" %>>Runter</button>
                  <button class="button-secondary" type="button" data-workflow-status-remove <%= isEditable ? "" : "disabled" %>>Loeschen</button>
                </div>
              </div>
            </template>
            <div class="template-lifecycle-actions">
              <button class="button-secondary" type="button" data-workflow-status-add <%= isEditable ? "" : "disabled" %>>Status hinzufuegen</button>
            </div>
          </div>
        </div>
      </div>

      <div class="table-wrap">
        <table class="workflow-transition-table workflow-transition-editor-table">
          <thead>
            <tr>
              <th>Action</th>
              <th>From</th>
              <th>To</th>
              <th>Roles</th>
              <th>Mode</th>
              <th>API</th>
              <th>Condition</th>
            </tr>
          </thead>
          <tbody>
            <% editableRows.forEach((row, index) => { %>
              <tr>
                <td><input class="text-input" type="text" name="actionName__<%= index %>" value="<%= row.actionName %>" placeholder="submit" <%= isEditable ? "" : "readonly" %> /></td>
                <td>
                  <select class="text-input" name="actionFrom__<%= index %>" data-workflow-action-status-select data-placeholder-label="From" <%= isEditable ? "" : "disabled" %>>
                    <option value="">From</option>
                    <% workflowDetail.availableStatusOptions.forEach((status) => { %>
                      <option value="<%= status %>" <%= row.from[0] === status ? "selected" : "" %>><%= status %></option>
                    <% }) %>
                  </select>
                </td>
                <td>
                  <select class="text-input" name="actionTo__<%= index %>" data-workflow-action-status-select data-placeholder-label="To" <%= isEditable ? "" : "disabled" %>>
                    <option value="">To</option>
                    <% workflowDetail.availableStatusOptions.forEach((status) => { %>
                      <option value="<%= status %>" <%= row.to === status ? "selected" : "" %>><%= status %></option>
                    <% }) %>
                  </select>
                </td>
                <td>
                  <select class="text-input" name="actionRole__<%= index %>" <%= isEditable ? "" : "disabled" %>>
                    <option value="">Rolle</option>
                    <% workflowDetail.availableRoleOptions.forEach((roleOption) => { %>
                      <option value="<%= roleOption.value %>" <%= row.roles[0] === roleOption.value ? "selected" : "" %>><%= roleOption.label %></option>
                    <% }) %>
                  </select>
                </td>
                <td>
                  <select class="text-input" name="actionMode__<%= index %>" <%= isEditable ? "" : "disabled" %>>
                    <option value="OR" <%= row.modeLabel === "OR" ? "selected" : "" %>>OR</option>
                    <option value="AND" <%= row.modeLabel === "AND" ? "selected" : "" %>>AND</option>
                  </select>
                </td>
                <td><input class="text-input" type="text" name="actionApi__<%= index %>" value="<%= row.apiLabel === '—' ? '' : row.apiLabel %>" list="workflow-api-options" placeholder="optional" <%= isEditable ? "" : "readonly" %> /></td>
                <td><input class="text-input" type="text" name="actionCondition__<%= index %>" value="<%= row.conditionLabel === '—' ? '' : row.conditionLabel %>" placeholder='optional' <%= isEditable ? "" : "readonly" %> /></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <datalist id="workflow-api-options">
        <% workflowDetail.availableOperations.forEach((operation) => { %>
          <option value="<%= operation.key %>"><%= operation.title %></option>
        <% }) %>
      </datalist>
    </article>
  </form>

  <% if (!isEditable) { %>
    <div class="notice-card">
      <strong>Readonly-Ansicht</strong>
      <p>Diese Workflow-Version ist derzeit nicht im Bearbeitungsmodus geöffnet. Bearbeiten startet oder öffnet den aktuellen Draft.</p>
    </div>
  <% } %>
</section>

<section class="panel">
  <div class="panel-header">
    <h3>Zugeordnete Formulare</h3>
    <span><%= workflowDetail.relatedTemplates.length %> Formulare</span>
  </div>
  <% if (workflowDetail.relatedTemplates.length === 0) { %>
    <div class="empty-state">
      <strong>Keine Formulare zugeordnet.</strong>
      <p>Dieser Workflow ist aktuell keinem sichtbaren Formular zugewiesen.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Formular</th>
            <th>Status</th>
            <th>Version</th>
            <th>Vorgänge</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <% workflowDetail.relatedTemplates.forEach((template) => { %>
            <% const relatedDocumentCount = workflowDetail.relatedDocuments.filter((document) => document.templateId === template.id).length; %>
            <tr>
              <td>
                <strong><%= template.name %></strong>
                <p class="table-meta"><%= template.key %></p>
              </td>
              <td><span class="status-pill status-<%= template.status %>"><%= template.status %></span></td>
              <td>v<%= template.version %></td>
              <td><%= relatedDocumentCount %></td>
              <td><a class="text-link" href="<%= hrefWithContext(`/templates/${template.id}`) %>">Zum Formular</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<dialog id="workflow-json-dialog" class="workflow-json-dialog">
  <div class="workflow-json-dialog-card">
    <div class="panel-header">
      <h4>Workflow JSON</h4>
      <button class="button-secondary" type="button" data-modal-close onclick="this.closest('dialog')?.close()">Schliessen</button>
    </div>
    <form method="post" action="<%= hrefWithContext(`/workflows/${workflowDetail.workflow.id}/source`) %>" class="stack-list">
      <input type="hidden" name="sourceMode" value="json" />
      <textarea name="source" rows="24" class="form-runtime-source-editor" data-code-editor="json" <%= isEditable ? "" : "readonly" %>><%= workflowDetail.workflowSourceText %></textarea>
      <div class="template-lifecycle-actions">
        <button class="button-secondary" type="submit" name="intent" value="save_draft" <%= isEditable ? "" : "disabled" %>>Save Draft v<%= workflowDetail.nextDraftVersion %></button>
        <button class="button-primary" type="submit" name="intent" value="publish" <%= isEditable && workflowDetail.canPublishVersion ? "" : "disabled" %>>Publish v<%= workflowDetail.publishTargetVersion %></button>
      </div>
    </form>
  </div>
</dialog>
