<% if (formRuntimeStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Gespeichert</strong>
    <p><%= formRuntimeStatus %></p>
  </div>
<% } %>

<% if (formRuntimeError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Nicht moeglich</strong>
    <p><%= formRuntimeError %></p>
  </div>
<% } %>

<% if (assignStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Zugewiesen</strong>
    <p><%= assignStatus %></p>
  </div>
<% } %>

<% if (assignError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Assign blockiert</strong>
    <p><%= assignError %></p>
  </div>
<% } %>

<% if (submitStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Eingereicht</strong>
    <p><%= submitStatus %></p>
  </div>
<% } %>

<% if (submitError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Submit blockiert</strong>
    <p><%= submitError %></p>
  </div>
<% } %>

<% if (approveStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Freigegeben</strong>
    <p><%= approveStatus %></p>
  </div>
<% } %>

<% if (approveError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Approve blockiert</strong>
    <p><%= approveError %></p>
  </div>
<% } %>

<% if (rejectStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Zurueckgewiesen</strong>
    <p><%= rejectStatus %></p>
  </div>
<% } %>

<% if (rejectError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Reject blockiert</strong>
    <p><%= rejectError %></p>
  </div>
<% } %>

<% if (reassignStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Neu zugewiesen</strong>
    <p><%= reassignStatus %></p>
  </div>
<% } %>

<% if (reassignError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Neu zuweisen blockiert</strong>
    <p><%= reassignError %></p>
  </div>
<% } %>

<% if (archiveStatus) { %>
  <div class="notice-card notice-success notice-inline">
    <strong>Archiviert</strong>
    <p><%= archiveStatus %></p>
  </div>
<% } %>

<% if (archiveError) { %>
  <div class="notice-card notice-error notice-inline">
    <strong>Archiv blockiert</strong>
    <p><%= archiveError %></p>
  </div>
<% } %>

<% const formRuntimeEditState = documentDetail.formRuntimeReference?.editState ?? documentDetail.editState; %>
<% const participantProgress = documentDetail.formRuntimeReference?.participantProgress; %>
<% const assignableEditors = documentDetail.assignableEditors ?? []; %>

<div class="form-runtime-toolbar">
  <% if (participantProgress) { %>
    <div class="workflow-action-strip workflow-action-strip-meta">
      <span>Deine Rollen: <%= participantProgress.currentUserRoles.length > 0 ? participantProgress.currentUserRoles.join(", ") : "keine" %></span>
      <span>Submit <%= participantProgress.submitModeLabel %> · <%= participantProgress.submitProgressLabel %></span>
      <span>Approve <%= participantProgress.approvalModeLabel %></span>
    </div>
  <% } %>
  <% if ((documentDetail.assignState?.isAvailable || documentDetail.reassignState?.isAvailable) && assignableEditors.length > 0) { %>
    <div class="workflow-action-strip workflow-action-strip-meta">
      <span>Editoren fuer Zuweisung</span>
      <div class="choice-grid compact">
        <% assignableEditors.forEach((editor) => { %>
          <label class="checkbox-item">
            <input type="checkbox" name="editorUserIds" value="<%= editor.userId %>" <%= editor.isSelected ? "checked" : "" %> />
            <span><%= editor.displayName %></span>
          </label>
        <% }) %>
      </div>
    </div>
  <% } %>
  <div class="workflow-action-strip">
    <button
      type="submit"
      class="button-primary"
      name="intent"
      value="save-form-runtime"
      data-preserve-form-position="true"
      hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>"
      hx-target="#document-form-body-fragment"
      hx-swap="outerHTML"
      <%= formRuntimeEditState.isAvailable ? "" : "disabled" %>
    >Speichern</button>
    <% if (documentDetail.assignState?.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/assign?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/assign?user=<%= activeUser.key %>"
        hx-target="#document-form-body-fragment"
        hx-swap="outerHTML"
        data-preserve-form-position="true"
      >Zuweisen</button>
    <% } else if (documentDetail.document.status === "draft") { %>
      <button class="button-secondary" type="button" disabled>Zuweisen</button>
    <% } %>
    <% if (documentDetail.submitState.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/submit?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/submit?user=<%= activeUser.key %>"
        hx-target="#document-form-body-fragment"
        hx-swap="outerHTML"
        data-preserve-form-position="true"
      >Einreichen und speichern</button>
    <% } else if (documentDetail.document.status === "created") { %>
      <button class="button-secondary" type="button" disabled>Einreichen</button>
    <% } %>
    <% if (documentDetail.approveState.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/approve?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/approve?user=<%= activeUser.key %>"
        hx-target="#document-form-body-fragment"
        hx-swap="outerHTML"
        data-preserve-form-position="true"
      >Freigeben</button>
    <% } %>
    <% if (documentDetail.reassignState?.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/reassign?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/reassign?user=<%= activeUser.key %>"
        hx-target="#document-form-body-fragment"
        hx-swap="outerHTML"
        data-preserve-form-position="true"
      >Neu zuweisen</button>
    <% } %>
    <% if (documentDetail.rejectState.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/reject?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/reject?user=<%= activeUser.key %>"
        hx-target="#document-form-body-fragment"
        hx-swap="outerHTML"
        data-preserve-form-position="true"
      >Zurueckweisen</button>
    <% } %>
  </div>
</div>
