<% if (documentDetail.formRuntimeReference.parseError) { %>
  <div class="notice-card notice-error">
    <strong>Formularquelle aktuell nicht lesbar</strong>
    <p><%= documentDetail.formRuntimeReference.parseError %></p>
  </div>
<% } else if (documentDetail.formRuntimeReference.parsedForm) { %>
  <% const masterDataSections = documentDetail.formRuntimeReference.masterDataSections ?? []; %>
  <% const linkedFormReferences = documentDetail.formRuntimeReference.linkedFormReferences ?? []; %>
  <% const participantProgress = documentDetail.formRuntimeReference.participantProgress; %>
  <% const qualificationPaging = documentDetail.formRuntimeReference.qualificationPaging; %>
  <% const qualificationEvaluation = documentDetail.formRuntimeReference.qualificationEvaluation; %>
  <% const customerMasterSection = masterDataSections.find((section) => section.key === "customer"); %>
  <% const productMasterSection = masterDataSections.find((section) => section.key === "product"); %>
  <% const productionBatchReference = linkedFormReferences.find((section) => section.key === "production_batch"); %>
  <% const visibleSections = qualificationPaging
    ? documentDetail.formRuntimeReference.parsedForm.sections.filter((section) => qualificationPaging.visibleSectionTitles.includes(section.title))
    : documentDetail.formRuntimeReference.parsedForm.sections; %>
  <div class="form-runtime-readonly-stack">
    <% if (documentDetail.formRuntimeReference.bootstrapError) { %>
      <div class="notice-card notice-error notice-inline">
        <strong>Auftragsliste nicht verfügbar</strong>
        <p><%= documentDetail.formRuntimeReference.bootstrapError %></p>
      </div>
    <% } %>
    <% (documentDetail.formRuntimeReference.hiddenFieldNames ?? []).forEach((fieldName) => { %>
      <input type="hidden" name="<%= fieldName %>" value="<%= documentDetail.formRuntimeReference.fieldValues[fieldName] ?? "" %>" />
    <% }) %>
    <% if (qualificationPaging) { %>
      <input type="hidden" name="qualification_current_page" value="<%= qualificationPaging.currentPage %>" />
    <% } %>
    <% if (participantProgress) { %>
      <article class="subpanel form-runtime-masterdata-section" data-participation-progress="qualification">
        <div class="panel-header">
          <h4>Beteiligte</h4>
          <span>Submit <%= participantProgress.submitModeLabel %> · <%= participantProgress.submitProgressLabel %></span>
        </div>
        <div class="table-wrap">
          <table class="form-runtime-grid-table is-readonly">
            <thead>
              <tr>
                <th>User</th>
                <th>Rolle</th>
                <th>Save</th>
                <th>Submit</th>
                <th>Signatur</th>
                <th>Stand</th>
              </tr>
            </thead>
            <tbody>
              <% participantProgress.rows.forEach((row) => { %>
                <tr <%= row.isCurrentUser ? 'data-current-user-row="true"' : "" %>>
                  <td><strong><%= row.displayName %></strong></td>
                  <td><%= row.participationLabel %><% if (row.workflowRoles.length > 0) { %><br /><span class="table-meta"><%= row.workflowRoles.join(", ") %></span><% } %></td>
                  <td><%= row.saved ? "ja" : "offen" %></td>
                  <td><%= row.submitted ? "ja" : "offen" %></td>
                  <td><%= row.signed ? "ja" : "offen" %></td>
                  <td><%= row.lastUpdatedAt ? new Date(row.lastUpdatedAt).toLocaleString("de-DE") : "—" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    <% } %>
    <% if (qualificationEvaluation) { %>
      <article class="subpanel form-runtime-evaluation-card form-runtime-evaluation-card-summary" data-form-section="qualification-evaluation-summary">
        <div class="panel-header">
          <h4>Auswertung</h4>
          <span><%= qualificationEvaluation.evaluationStatus %></span>
        </div>
        <div class="form-runtime-readonly-row form-runtime-columns-4">
          <div class="field-block">
            <label class="field-label">Status</label>
            <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.evaluationStatus %></div>
          </div>
          <div class="field-block">
            <label class="field-label">Score</label>
            <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.scoreValue %></div>
          </div>
          <div class="field-block">
            <label class="field-label">Pass</label>
            <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.passed ? "ja" : "nein" %></div>
          </div>
          <div class="field-block">
            <label class="field-label">Ausgewertet</label>
            <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.evaluatedAt ? new Date(qualificationEvaluation.evaluatedAt).toLocaleString("de-DE") : "—" %></div>
          </div>
        </div>
      </article>
    <% } %>
    <% if (qualificationPaging) { %>
      <article class="subpanel form-runtime-page-nav" data-form-section="qualification-page-nav">
        <div class="panel-header">
          <h4><%= qualificationPaging.currentPageTitle %></h4>
          <span>Seite <%= qualificationPaging.currentPage %> von <%= qualificationPaging.totalPages %></span>
        </div>
        <div class="form-runtime-page-actions">
          <% if (qualificationPaging.previousPage) { %>
            <button
              type="submit"
              class="button-secondary"
              name="page"
              value="<%= qualificationPaging.previousPage %>"
              data-preserve-form-position="true"
              formaction="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.previousPage %>"
              hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.previousPage %>"
              hx-target="#document-form-body-fragment"
              hx-swap="outerHTML"
            >Zurueck</button>
          <% } %>
          <% if (qualificationPaging.nextPage) { %>
            <button
              type="submit"
              class="button-primary"
              name="page"
              value="<%= qualificationPaging.nextPage %>"
              data-preserve-form-position="true"
              formaction="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.nextPage %>"
              hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.nextPage %>"
              hx-target="#document-form-body-fragment"
              hx-swap="outerHTML"
            >Weiter</button>
          <% } %>
        </div>
      </article>
    <% } %>
    <% visibleSections.forEach((section) => { %>
      <article class="subpanel form-runtime-readonly-section" data-form-section="<%= section.title.toLowerCase() %>">
        <div class="panel-header">
          <h4><%= section.title %></h4>
        </div>

        <% section.rows.forEach((row) => { %>
          <% const actionSlots = row.slots.filter((slot) => slot.element.kind !== "field"); %>
          <% const visibleSlots = row.slots.filter((slot) => slot.element.kind === "field"); %>
          <% const rowColumnCount = Math.min(Math.max(visibleSlots.length, 1), 3); %>
          <div class="form-runtime-readonly-row form-runtime-columns-<%= rowColumnCount %>">
            <% if (actionSlots.length > 0) { %>
              <div class="form-runtime-row-actions">
                <% actionSlots.forEach((slot) => { %>
                  <% var actionElement = slot.element; %>
                  <% var actionUi = documentDetail.formRuntimeReference.actionUi && documentDetail.formRuntimeReference.actionUi[actionElement.name]; %>
                  <% if (!actionUi) { %>
                    <% actionUi = { controlType: actionElement.controlType === "lookup" ? "lookup" : "action", runtimeRole: "lookup_trigger", lookupRole: "trigger", args: actionElement.args || [], bind: actionElement.bind || [], isEnabled: documentDetail.formRuntimeReference.editState.isAvailable }; %>
                  <% } %>
                  <button
                    type="submit"
                    class="button-secondary form-runtime-inline-action"
                    data-inline-action="<%= actionElement.name %>"
                    data-action-control-type="<%= actionUi.controlType %>"
                    data-action-runtime-role="<%= actionUi.runtimeRole %>"
                    data-action-lookup-role="<%= actionUi.lookupRole %>"
                    data-preserve-form-position="true"
                    formaction="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=run-action&actionName=<%= encodeURIComponent(actionElement.name) %>"
                    hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=run-action&actionName=<%= encodeURIComponent(actionElement.name) %>"
                    hx-target="#document-form-body-fragment"
                    hx-swap="outerHTML"
                    <% if (actionUi.isEnabled === false) { %>disabled<% } %>
                  ><%= actionElement.label ?? actionElement.name %></button>
                <% }) %>
              </div>
            <% } %>
            <% visibleSlots.forEach((slot) => { %>
              <% const element = slot.element; %>
              <% const currentValueText = documentDetail.formRuntimeReference.fieldValues[element.name] ?? ""; %>
              <% const fieldUi = documentDetail.formRuntimeReference.fieldUi?.[element.name] ?? { controlType: element.controlType, runtimeRole: "derived_readonly", lookupRole: "none", isSubmitRequired: false, isEditable: false, isReadOnly: true, state: "readonly" }; %>
              <% const emptyValueLabel = fieldUi.emptyValueLabel ?? (element.controlType === "select" ? "Noch keine Auswahl" : "Noch kein Wert"); %>
              <% const optionItems = fieldUi.optionItems ?? (typeof element.properties.options === "string" ? element.properties.options.split(",").map((option) => option.trim()).filter((option) => option.length > 0).map((option) => ({ value: option, label: option })) : []); %>
              <% const multiSelectedValues = currentValueText.split(",").map((entry) => entry.trim()).filter((entry) => entry.length > 0); %>
              <% const displayValue = fieldUi.displayValue ?? currentValueText; %>
              <% const propertyReadonly = element.properties.readonly === true; %>
              <% const isFieldEditable = fieldUi.isEditable && !propertyReadonly; %>
              <% const orderNumberPlaceholder = element.name === "order_number" ? "z. B. O-ca26a72f-1" : emptyValueLabel; %>
              <% const gridColumns = fieldUi.controlType === "grid" && typeof element.properties.columns === "string"
                ? element.properties.columns.split("|").map((column) => column.trim()).filter((column) => column.length > 0).map((column) => {
                  const [namePart, labelPart] = column.split(":");
                  const name = (namePart ?? "").trim();
                  const label = (labelPart ?? namePart ?? "").trim() || name;
                  const numberColumns = typeof element.properties.numberColumns === "string"
                    ? element.properties.numberColumns.split(",").map((entry) => entry.trim()).filter((entry) => entry.length > 0)
                    : [];

                  return {
                    name,
                    label,
                    inputMode: numberColumns.includes(name) ? "number" : "text",
                  };
                }).filter((column) => column.name.length > 0)
                : []; %>
              <% let parsedGridRows = []; %>
              <% if (fieldUi.controlType === "grid" && currentValueText.trim().length > 0) { %>
                <% try { %>
                  <% parsedGridRows = JSON.parse(currentValueText); %>
                <% } catch (_error) { %>
                  <% parsedGridRows = []; %>
                <% } %>
              <% } %>
              <% const gridRows = fieldUi.controlType === "grid" && Array.isArray(parsedGridRows)
                ? parsedGridRows.filter((row) => row && typeof row === "object")
                : []; %>
              <% const gridMinRows = fieldUi.controlType === "grid"
                ? Math.max(parseInt(String(element.properties.rows ?? "3"), 10) || 3, fieldUi.isEditable ? 1 : 0, gridRows.length)
                : 0; %>
              <% if (element.kind === "field") { %>
                <article
                  class="field-block form-runtime-readonly-field form-runtime-type-<%= element.controlType %>"
                  data-field-name="<%= element.name %>"
                  data-control-type="<%= fieldUi.controlType %>"
                  data-control-runtime-role="<%= fieldUi.runtimeRole %>"
                  data-control-lookup-role="<%= fieldUi.lookupRole %>"
                  data-field-required="<%= fieldUi.isSubmitRequired ? "true" : "false" %>"
                  data-field-state="<%= isFieldEditable ? "editable" : "readonly" %>">
                  <div class="form-runtime-field-head">
                    <label class="field-label"><%= element.label ?? element.name %><% if (fieldUi.isSubmitRequired) { %><span class="field-required" aria-hidden="true">*</span><span class="sr-only"> Pflichtfeld</span><% } %></label>
                  </div>

                  <% if (fieldUi.controlType === "html-editor") { %>
                    <% if (isFieldEditable) { %>
                      <div class="form-runtime-richtext" data-rich-text-control data-field-name="<%= element.name %>">
                        <div class="form-runtime-richtext-toolbar" role="toolbar" aria-label="Formatierung fuer <%= element.label ?? element.name %>">
                          <button type="button" class="button-secondary form-runtime-richtext-button" data-rich-text-command="formatBlock" data-rich-text-value="p">Absatz</button>
                          <button type="button" class="button-secondary form-runtime-richtext-button" data-rich-text-command="bold"><strong>B</strong></button>
                          <button type="button" class="button-secondary form-runtime-richtext-button" data-rich-text-command="italic"><em>I</em></button>
                          <button type="button" class="button-secondary form-runtime-richtext-button" data-rich-text-command="insertUnorderedList">Liste</button>
                        </div>
                        <div
                          class="form-runtime-richtext-surface"
                          contenteditable="true"
                          role="textbox"
                          aria-label="<%= element.label ?? element.name %>"
                          aria-multiline="true"
                          data-rich-text-editor
                          data-placeholder="<%= emptyValueLabel %>"
                        ><%- currentValueText %></div>
                        <textarea class="sr-only" name="<%= element.name %>" data-rich-text-input><%= currentValueText %></textarea>
                      </div>
                    <% } else { %>
                      <div class="form-runtime-richtext-readonly">
                        <% if (currentValueText) { %>
                          <%- currentValueText %>
                        <% } else { %>
                          <p class="form-runtime-richtext-empty"><%= emptyValueLabel %></p>
                        <% } %>
                      </div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "signature") { %>
                    <% const signatureAt = documentDetail.formRuntimeReference.fieldValues[`${element.name}_at`] ?? documentDetail.formRuntimeReference.fieldValues.work_signature_at ?? ""; %>
                    <% const signatureTimestampLabel = signatureAt ? new Date(signatureAt).toLocaleString("de-DE") : ""; %>
                    <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" />
                    <input type="hidden" name="<%= `${element.name}_at` %>" value="<%= signatureAt %>" />
                    <div class="form-runtime-signature-card <%= currentValueText ? "is-signed" : "" %>">
                      <strong><%= currentValueText || emptyValueLabel %></strong>
                      <% if (currentValueText && signatureTimestampLabel) { %>
                        <p><%= documentDetail.document.templateKey === "qualification-record" ? "Dein Stand" : "Signiert" %> · <%= signatureTimestampLabel %></p>
                      <% } else if (currentValueText) { %>
                        <p>Signatur liegt vor.</p>
                      <% } else { %>
                        <p><%= documentDetail.document.templateKey === "qualification-record" ? "Deine Signatur fehlt noch." : "Dokument kann mit aktuellem Nutzer signiert werden." %></p>
                      <% } %>
                    </div>
                    <% if (isFieldEditable) { %>
                      <div class="form-runtime-signature-actions">
                        <button
                          type="submit"
                          class="button-secondary form-runtime-inline-action"
                          name="work_signature_requested"
                          value="sign"
                          data-preserve-form-position="true"
                          formaction="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>"
                          hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>"
                          hx-target="#document-form-body-fragment"
                          hx-swap="outerHTML"
                        ><%= currentValueText ? "Signatur erneuern" : "Jetzt signieren" %></button>
                      </div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "grid") { %>
                    <% if (isFieldEditable) { %>
                      <div class="form-runtime-grid-control" data-grid-control data-field-name="<%= element.name %>">
                        <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" data-grid-input />
                        <div class="table-wrap">
                          <table class="form-runtime-grid-table">
                            <thead>
                              <tr>
                                <% gridColumns.forEach((column) => { %>
                                  <th><%= column.label %></th>
                                <% }) %>
                              </tr>
                            </thead>
                            <tbody>
                              <% Array.from({ length: gridMinRows }).forEach((_, rowIndex) => { %>
                                <% const rowValue = gridRows[rowIndex] && typeof gridRows[rowIndex] === "object" ? gridRows[rowIndex] : {}; %>
                                <tr>
                                  <% gridColumns.forEach((column) => { %>
                                    <% const gridCellValue = typeof rowValue[column.name] === "string" ? rowValue[column.name] : ""; %>
                                    <td>
                                      <input
                                        class="text-input form-runtime-grid-input"
                                        type="<%= column.inputMode === "number" ? "number" : "text" %>"
                                        <%= column.inputMode === "number" ? 'step="0.01"' : "" %>
                                        value="<%= gridCellValue %>"
                                        data-grid-cell
                                        data-grid-column="<%= column.name %>"
                                      />
                                    </td>
                                  <% }) %>
                                </tr>
                              <% }) %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                    <% } else if (gridRows.length > 0) { %>
                      <div class="table-wrap">
                        <table class="form-runtime-grid-table is-readonly">
                          <thead>
                            <tr>
                              <% gridColumns.forEach((column) => { %>
                                <th><%= column.label %></th>
                              <% }) %>
                            </tr>
                          </thead>
                          <tbody>
                            <% gridRows.forEach((rowValue) => { %>
                              <tr>
                                <% gridColumns.forEach((column) => { %>
                                  <% const cellValue = typeof rowValue[column.name] === "string" ? rowValue[column.name] : ""; %>
                                  <td><%= cellValue || "—" %></td>
                                <% }) %>
                              </tr>
                            <% }) %>
                          </tbody>
                        </table>
                      </div>
                    <% } else { %>
                      <div class="form-runtime-value form-runtime-value-readonly"><%= emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "user-select") { %>
                    <% if (isFieldEditable) { %>
                      <select class="text-input" name="<%= element.name %>">
                        <option value=""><%= emptyValueLabel %></option>
                        <% optionItems.forEach((option) => { %>
                          <option value="<%= option.value %>" <%= currentValueText === option.value ? "selected" : "" %>><%= option.label %></option>
                        <% }) %>
                      </select>
                    <% } else { %>
                      <div class="form-runtime-value form-runtime-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "user-multiselect") { %>
                    <% if (isFieldEditable) { %>
                      <div class="form-runtime-user-multiselect-control" data-user-multiselect-control>
                        <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" data-user-multiselect-input />
                        <select class="text-input form-runtime-user-multiselect" multiple data-user-multiselect-source>
                          <% optionItems.forEach((option) => { %>
                            <option value="<%= option.value %>" <%= multiSelectedValues.includes(option.value) ? "selected" : "" %>><%= option.label %></option>
                          <% }) %>
                        </select>
                      </div>
                    <% } else { %>
                      <div class="form-runtime-value form-runtime-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "radio-group") { %>
                    <% if (isFieldEditable) { %>
                      <div class="form-runtime-choice-group">
                        <% optionItems.forEach((option) => { %>
                          <label class="form-runtime-choice">
                            <input type="radio" name="<%= element.name %>" value="<%= option.value %>" <%= currentValueText === option.value ? "checked" : "" %> />
                            <span><%= option.label %></span>
                          </label>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <div class="form-runtime-value form-runtime-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "checkbox-group") { %>
                    <% if (isFieldEditable) { %>
                      <div class="form-runtime-choice-group">
                        <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" data-checkbox-group-input />
                        <% optionItems.forEach((option) => { %>
                          <label class="form-runtime-choice">
                            <input
                              type="checkbox"
                              value="<%= option.value %>"
                              data-checkbox-group-option
                              data-target-input="<%= element.name %>"
                              <%= multiSelectedValues.includes(option.value) ? "checked" : "" %>
                            />
                            <span><%= option.label %></span>
                          </label>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <div class="form-runtime-value form-runtime-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "textarea") { %>
                    <% if (fieldUi.isEditable) { %>
                      <textarea class="form-runtime-runtime-textarea" name="<%= element.name %>" placeholder="<%= emptyValueLabel %>"><%= currentValueText %></textarea>
                    <% } else { %>
                      <textarea class="form-runtime-runtime-textarea is-readonly" name="<%= element.name %>" placeholder="<%= emptyValueLabel %>" readonly><%= currentValueText %></textarea>
                    <% } %>
                  <% } else if (fieldUi.controlType === "select") { %>
                    <% if (isFieldEditable) { %>
                      <% if (fieldUi.runtimeRole === "lookup_input") { %>
                        <select class="text-input" name="<%= element.name %>">
                          <option value=""><%= emptyValueLabel %></option>
                          <% if (currentValueText && !optionItems.some((option) => option.value === currentValueText)) { %>
                            <option value="<%= currentValueText %>" selected><%= currentValueText %></option>
                          <% } %>
                          <% optionItems.forEach((option) => { %>
                            <option value="<%= option.value %>" <%= currentValueText === option.value ? "selected" : "" %>><%= option.label %></option>
                          <% }) %>
                        </select>
                        <% if (optionItems.length === 0) { %>
                          <p class="field-help">Noch keine Dropdown-Werte geladen. Bitte die zugehörige ERP-Aktion ausführen.</p>
                        <% } %>
                      <% } else { %>
                        <select class="text-input" name="<%= element.name %>">
                          <option value=""><%= emptyValueLabel %></option>
                          <% optionItems.forEach((option) => { %>
                            <option value="<%= option.value %>" <%= currentValueText === option.value ? "selected" : "" %>><%= option.label %></option>
                          <% }) %>
                        </select>
                      <% } %>
                    <% } else { %>
                      <div class="form-runtime-value form-runtime-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "date") { %>
                    <input class="text-input <%= isFieldEditable ? "" : "text-input-readonly" %>" type="date" name="<%= element.name %>" value="<%= currentValueText %>" <%= isFieldEditable ? "" : "readonly" %> />
                  <% } else if (fieldUi.controlType === "number") { %>
                    <input class="text-input <%= isFieldEditable ? "" : "text-input-readonly" %>" type="number" step="0.25" min="0" name="<%= element.name %>" value="<%= currentValueText %>" placeholder="<%= emptyValueLabel %>" <%= isFieldEditable ? "" : "readonly" %> />
                  <% } else { %>
                    <input class="text-input <%= isFieldEditable ? "" : "text-input-readonly" %>" type="text" name="<%= element.name %>" value="<%= currentValueText %>" placeholder="<%= orderNumberPlaceholder %>" <%= isFieldEditable ? "" : "readonly" %> />
                  <% } %>
                </article>
              <% } %>
            <% }) %>
          </div>
        <% }) %>

        <% if (section.title === "Kunde" && customerMasterSection) { %>
          <article class="subpanel form-runtime-masterdata-section" data-masterdata-section="customer">
            <div class="panel-header">
              <h4><%= customerMasterSection.title %></h4>
            </div>
            <div class="form-runtime-masterdata-grid">
              <% customerMasterSection.entries.forEach((entry) => { %>
                <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                  <label class="field-label"><%= entry.label %></label>
                  <div class="form-runtime-value form-runtime-value-readonly"><%= entry.value || entry.emptyValueLabel %></div>
                </article>
              <% }) %>
            </div>
          </article>
        <% } %>

        <% if (section.title === "Leistung" && productMasterSection) { %>
          <article class="subpanel form-runtime-masterdata-section" data-masterdata-section="product">
            <div class="panel-header">
              <h4><%= productMasterSection.title %></h4>
            </div>
            <div class="form-runtime-masterdata-grid">
              <% productMasterSection.entries.forEach((entry) => { %>
                <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                  <label class="field-label"><%= entry.label %></label>
                  <div class="form-runtime-value form-runtime-value-readonly"><%= entry.value || entry.emptyValueLabel %></div>
                </article>
              <% }) %>
            </div>
          </article>
        <% } %>

        <% if (section.title === "Leistung" && productionBatchReference) { %>
          <article class="subpanel form-runtime-masterdata-section" data-form-reference-section="production_batch">
            <div class="panel-header">
              <h4><%= productionBatchReference.title %></h4>
              <a class="text-link" href="<%= productionBatchReference.href %>">Dokument öffnen</a>
            </div>
            <div class="form-runtime-masterdata-grid">
              <% productionBatchReference.entries.forEach((entry) => { %>
                <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                  <label class="field-label"><%= entry.label %></label>
                  <div class="form-runtime-value form-runtime-value-readonly"><%= entry.value || entry.emptyValueLabel %></div>
                </article>
              <% }) %>
            </div>
          </article>
        <% } %>

        <% if (section.title === "Freigabe" && qualificationEvaluation) { %>
          <article class="subpanel form-runtime-evaluation-card" data-form-section="qualification-evaluation">
            <div class="panel-header">
              <h4>Auswertung</h4>
              <span><%= qualificationEvaluation.evaluationStatus %></span>
            </div>
            <div class="form-runtime-masterdata-grid">
              <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                <label class="field-label">Status</label>
                <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.evaluationStatus %></div>
              </article>
              <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                <label class="field-label">Score</label>
                <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.scoreValue %></div>
              </article>
              <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                <label class="field-label">Pass</label>
                <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.passed ? "ja" : "nein" %></div>
              </article>
              <article class="field-block form-runtime-readonly-field form-runtime-masterdata-entry">
                <label class="field-label">Ausgewertet</label>
                <div class="form-runtime-value form-runtime-value-readonly"><%= qualificationEvaluation.evaluatedAt ? new Date(qualificationEvaluation.evaluatedAt).toLocaleString("de-DE") : "—" %></div>
              </article>
            </div>
          </article>
        <% } %>
      </article>
    <% }) %>
    <% if (qualificationPaging) { %>
      <article class="subpanel form-runtime-page-nav is-footer" data-form-section="qualification-page-nav-footer">
        <div class="form-runtime-page-actions">
          <% if (qualificationPaging.previousPage) { %>
            <button
              type="submit"
              class="button-secondary"
              name="page"
              value="<%= qualificationPaging.previousPage %>"
              data-preserve-form-position="true"
              formaction="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.previousPage %>"
              hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.previousPage %>"
              hx-target="#document-form-body-fragment"
              hx-swap="outerHTML"
            >Zurueck</button>
          <% } %>
          <span>Seite <%= qualificationPaging.currentPage %> von <%= qualificationPaging.totalPages %></span>
          <% if (qualificationPaging.nextPage) { %>
            <button
              type="submit"
              class="button-primary"
              name="page"
              value="<%= qualificationPaging.nextPage %>"
              data-preserve-form-position="true"
              formaction="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.nextPage %>"
              hx-post="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>&intent=navigate-page&page=<%= qualificationPaging.nextPage %>"
              hx-target="#document-form-body-fragment"
              hx-swap="outerHTML"
            >Weiter</button>
          <% } %>
        </div>
      </article>
    <% } %>
  </div>
<% } %>
