<% if (documentDetail.nextFormReference.parseError) { %>
  <div class="notice-card notice-error">
    <strong>Formularquelle aktuell nicht lesbar</strong>
    <p><%= documentDetail.nextFormReference.parseError %></p>
  </div>
<% } else if (documentDetail.nextFormReference.parsedForm) { %>
  <% const masterDataSections = documentDetail.nextFormReference.masterDataSections ?? []; %>
  <% const linkedFormReferences = documentDetail.nextFormReference.linkedFormReferences ?? []; %>
  <% const participantProgress = documentDetail.nextFormReference.participantProgress; %>
  <% const customerMasterSection = masterDataSections.find((section) => section.key === "customer"); %>
  <% const productMasterSection = masterDataSections.find((section) => section.key === "product"); %>
  <% const productionBatchReference = linkedFormReferences.find((section) => section.key === "production_batch"); %>
  <div class="next-form-readonly-stack">
    <% (documentDetail.nextFormReference.hiddenFieldNames ?? []).forEach((fieldName) => { %>
      <input type="hidden" name="<%= fieldName %>" value="<%= documentDetail.nextFormReference.fieldValues[fieldName] ?? "" %>" />
    <% }) %>
    <% if (participantProgress) { %>
      <article class="subpanel next-form-masterdata-section" data-participation-progress="qualification">
        <div class="panel-header">
          <h4>Beteiligte</h4>
          <span>Submit <%= participantProgress.submitModeLabel %> · <%= participantProgress.submitProgressLabel %></span>
        </div>
        <div class="table-wrap">
          <table class="next-form-grid-table is-readonly">
            <thead>
              <tr>
                <th>User</th>
                <th>Rolle</th>
                <th>Save</th>
                <th>Submit</th>
                <th>Signatur</th>
                <th>Stand</th>
              </tr>
            </thead>
            <tbody>
              <% participantProgress.rows.forEach((row) => { %>
                <tr <%= row.isCurrentUser ? 'data-current-user-row="true"' : "" %>>
                  <td><strong><%= row.displayName %></strong></td>
                  <td><%= row.participationLabel %><% if (row.workflowRoles.length > 0) { %><br /><span class="table-meta"><%= row.workflowRoles.join(", ") %></span><% } %></td>
                  <td><%= row.saved ? "ja" : "offen" %></td>
                  <td><%= row.submitted ? "ja" : "offen" %></td>
                  <td><%= row.signed ? "ja" : "offen" %></td>
                  <td><%= row.lastUpdatedAt ? new Date(row.lastUpdatedAt).toLocaleString("de-DE") : "—" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    <% } %>
    <% documentDetail.nextFormReference.parsedForm.sections.forEach((section) => { %>
      <article class="subpanel next-form-readonly-section" data-form-section="<%= section.title.toLowerCase() %>">
        <div class="panel-header">
          <h4><%= section.title %></h4>
        </div>

        <% section.rows.forEach((row) => { %>
          <% const inlineLoadCustomerAction = row.slots.find((slot) => slot.element.name === "load_customer"); %>
          <% const inlineSuggestMaterialAction = row.slots.find((slot) => slot.element.name === "suggest_material"); %>
          <% const visibleSlots = row.slots.filter((slot) => !["load_customer", "suggest_material"].includes(slot.element.name)); %>
          <div class="next-form-readonly-row next-form-columns-<%= Math.min(Math.max(visibleSlots.length, 1), 3) %>">
            <% row.slots.forEach((slot) => { %>
              <% const element = slot.element; %>
              <% const currentValueText = documentDetail.nextFormReference.fieldValues[element.name] ?? ""; %>
              <% const fieldUi = documentDetail.nextFormReference.fieldUi?.[element.name] ?? { controlType: element.controlType, runtimeRole: "derived_readonly", lookupRole: "none", isSubmitRequired: false, isEditable: false, isReadOnly: true, state: "readonly" }; %>
              <% const actionUi = documentDetail.nextFormReference.actionUi?.[element.name]; %>
              <% const emptyValueLabel = fieldUi.emptyValueLabel ?? (element.controlType === "select" ? "Noch keine Auswahl" : "Noch kein Wert"); %>
              <% const optionItems = fieldUi.optionItems ?? (typeof element.properties.options === "string" ? element.properties.options.split(",").map((option) => option.trim()).filter((option) => option.length > 0).map((option) => ({ value: option, label: option })) : []); %>
              <% const multiSelectedValues = currentValueText.split(",").map((entry) => entry.trim()).filter((entry) => entry.length > 0); %>
              <% const displayValue = fieldUi.displayValue ?? currentValueText; %>
              <% const orderNumberPlaceholder = element.name === "order_number" ? "z. B. O-ca26a72f-1" : emptyValueLabel; %>
              <% const gridColumns = fieldUi.controlType === "grid" && typeof element.properties.columns === "string"
                ? element.properties.columns.split("|").map((column) => column.trim()).filter((column) => column.length > 0).map((column) => {
                  const [namePart, labelPart] = column.split(":");
                  const name = (namePart ?? "").trim();
                  const label = (labelPart ?? namePart ?? "").trim() || name;
                  const numberColumns = typeof element.properties.numberColumns === "string"
                    ? element.properties.numberColumns.split(",").map((entry) => entry.trim()).filter((entry) => entry.length > 0)
                    : [];

                  return {
                    name,
                    label,
                    inputMode: numberColumns.includes(name) ? "number" : "text",
                  };
                }).filter((column) => column.name.length > 0)
                : []; %>
              <% let parsedGridRows = []; %>
              <% if (fieldUi.controlType === "grid" && currentValueText.trim().length > 0) { %>
                <% try { %>
                  <% parsedGridRows = JSON.parse(currentValueText); %>
                <% } catch (_error) { %>
                  <% parsedGridRows = []; %>
                <% } %>
              <% } %>
              <% const gridRows = fieldUi.controlType === "grid" && Array.isArray(parsedGridRows)
                ? parsedGridRows.filter((row) => row && typeof row === "object")
                : []; %>
              <% const gridMinRows = fieldUi.controlType === "grid"
                ? Math.max(parseInt(String(element.properties.rows ?? "3"), 10) || 3, fieldUi.isEditable ? 1 : 0, gridRows.length)
                : 0; %>
              <% if (element.kind === "field") { %>
                <article
                  class="field-block next-form-readonly-field next-form-type-<%= element.controlType %>"
                  data-field-name="<%= element.name %>"
                  data-control-type="<%= fieldUi.controlType %>"
                  data-control-runtime-role="<%= fieldUi.runtimeRole %>"
                  data-control-lookup-role="<%= fieldUi.lookupRole %>"
                  data-field-required="<%= fieldUi.isSubmitRequired ? "true" : "false" %>"
                  data-field-state="<%= fieldUi.state %>">
                  <div class="next-form-field-head">
                    <label class="field-label"><%= element.label ?? element.name %><% if (fieldUi.isSubmitRequired) { %><span class="field-required" aria-hidden="true">*</span><span class="sr-only"> Pflichtfeld</span><% } %></label>
                    <div class="next-form-field-side">
                      <% if (element.name === "order_number" && inlineLoadCustomerAction) { %>
                        <button
                          type="submit"
                          class="button-secondary next-form-inline-action"
                          data-inline-action="load_customer"
                          data-action-control-type="<%= actionUi?.controlType ?? "action" %>"
                          data-action-runtime-role="<%= actionUi?.runtimeRole ?? "lookup_trigger" %>"
                          data-action-lookup-role="<%= actionUi?.lookupRole ?? "trigger" %>"
                          data-preserve-form-position="true"
                          formaction="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>&intent=run-action&actionName=load_customer"
                          hx-post="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>&intent=run-action&actionName=load_customer"
                          hx-target="#document-form-body-fragment"
                          hx-swap="outerHTML"
                          <%= documentDetail.nextFormReference.actionUi?.load_customer?.isEnabled === false ? "disabled" : "" %>
                        >Kundendaten laden</button>
                      <% } %>
                      <% if (element.name === "material" && inlineSuggestMaterialAction) { %>
                        <button
                          type="submit"
                          class="button-secondary next-form-inline-action"
                          data-inline-action="suggest_material"
                          data-action-control-type="<%= actionUi?.controlType ?? "lookup" %>"
                          data-action-runtime-role="<%= actionUi?.runtimeRole ?? "lookup_trigger" %>"
                          data-action-lookup-role="<%= actionUi?.lookupRole ?? "trigger" %>"
                          data-preserve-form-position="true"
                          formaction="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>&intent=run-action&actionName=suggest_material"
                          hx-post="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>&intent=run-action&actionName=suggest_material"
                          hx-target="#document-form-body-fragment"
                          hx-swap="outerHTML"
                          <%= documentDetail.nextFormReference.actionUi?.suggest_material?.isEnabled === false ? "disabled" : "" %>
                        >Materialvorschlag holen</button>
                      <% } %>
                    </div>
                  </div>

                  <% if (fieldUi.controlType === "html-editor") { %>
                    <% if (fieldUi.isEditable) { %>
                      <div class="next-form-richtext" data-rich-text-control data-field-name="<%= element.name %>">
                        <div class="next-form-richtext-toolbar" role="toolbar" aria-label="Formatierung fuer <%= element.label ?? element.name %>">
                          <button type="button" class="button-secondary next-form-richtext-button" data-rich-text-command="formatBlock" data-rich-text-value="p">Absatz</button>
                          <button type="button" class="button-secondary next-form-richtext-button" data-rich-text-command="bold"><strong>B</strong></button>
                          <button type="button" class="button-secondary next-form-richtext-button" data-rich-text-command="italic"><em>I</em></button>
                          <button type="button" class="button-secondary next-form-richtext-button" data-rich-text-command="insertUnorderedList">Liste</button>
                        </div>
                        <div
                          class="next-form-richtext-surface"
                          contenteditable="true"
                          role="textbox"
                          aria-label="<%= element.label ?? element.name %>"
                          aria-multiline="true"
                          data-rich-text-editor
                          data-placeholder="<%= emptyValueLabel %>"
                        ><%- currentValueText %></div>
                        <textarea class="sr-only" name="<%= element.name %>" data-rich-text-input><%= currentValueText %></textarea>
                      </div>
                    <% } else { %>
                      <div class="next-form-richtext-readonly">
                        <% if (currentValueText) { %>
                          <%- currentValueText %>
                        <% } else { %>
                          <p class="next-form-richtext-empty"><%= emptyValueLabel %></p>
                        <% } %>
                      </div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "signature") { %>
                    <% const signatureAt = documentDetail.nextFormReference.fieldValues[`${element.name}_at`] ?? documentDetail.nextFormReference.fieldValues.work_signature_at ?? ""; %>
                    <% const signatureTimestampLabel = signatureAt ? new Date(signatureAt).toLocaleString("de-DE") : ""; %>
                    <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" />
                    <input type="hidden" name="<%= `${element.name}_at` %>" value="<%= signatureAt %>" />
                    <div class="next-form-signature-card <%= currentValueText ? "is-signed" : "" %>">
                      <strong><%= currentValueText || emptyValueLabel %></strong>
                      <% if (currentValueText && signatureTimestampLabel) { %>
                        <p><%= documentDetail.document.templateKey === "qualification-record" ? "Dein Stand" : "Signiert" %> · <%= signatureTimestampLabel %></p>
                      <% } else if (currentValueText) { %>
                        <p>Signatur liegt vor.</p>
                      <% } else { %>
                        <p><%= documentDetail.document.templateKey === "qualification-record" ? "Deine Signatur fehlt noch." : "Dokument kann mit aktuellem Nutzer signiert werden." %></p>
                      <% } %>
                    </div>
                    <% if (fieldUi.isEditable) { %>
                      <div class="next-form-signature-actions">
                        <button
                          type="submit"
                          class="button-secondary next-form-inline-action"
                          name="work_signature_requested"
                          value="sign"
                          data-preserve-form-position="true"
                          formaction="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>"
                          hx-post="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>"
                          hx-target="#document-form-body-fragment"
                          hx-swap="outerHTML"
                        ><%= currentValueText ? "Signatur erneuern" : "Jetzt signieren" %></button>
                      </div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "grid") { %>
                    <% if (fieldUi.isEditable) { %>
                      <div class="next-form-grid-control" data-grid-control data-field-name="<%= element.name %>">
                        <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" data-grid-input />
                        <div class="table-wrap">
                          <table class="next-form-grid-table">
                            <thead>
                              <tr>
                                <% gridColumns.forEach((column) => { %>
                                  <th><%= column.label %></th>
                                <% }) %>
                              </tr>
                            </thead>
                            <tbody>
                              <% Array.from({ length: gridMinRows }).forEach((_, rowIndex) => { %>
                                <% const rowValue = gridRows[rowIndex] && typeof gridRows[rowIndex] === "object" ? gridRows[rowIndex] : {}; %>
                                <tr>
                                  <% gridColumns.forEach((column) => { %>
                                    <% const gridCellValue = typeof rowValue[column.name] === "string" ? rowValue[column.name] : ""; %>
                                    <td>
                                      <input
                                        class="text-input next-form-grid-input"
                                        type="<%= column.inputMode === "number" ? "number" : "text" %>"
                                        <%= column.inputMode === "number" ? 'step="0.01"' : "" %>
                                        value="<%= gridCellValue %>"
                                        data-grid-cell
                                        data-grid-column="<%= column.name %>"
                                      />
                                    </td>
                                  <% }) %>
                                </tr>
                              <% }) %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                    <% } else if (gridRows.length > 0) { %>
                      <div class="table-wrap">
                        <table class="next-form-grid-table is-readonly">
                          <thead>
                            <tr>
                              <% gridColumns.forEach((column) => { %>
                                <th><%= column.label %></th>
                              <% }) %>
                            </tr>
                          </thead>
                          <tbody>
                            <% gridRows.forEach((rowValue) => { %>
                              <tr>
                                <% gridColumns.forEach((column) => { %>
                                  <% const cellValue = typeof rowValue[column.name] === "string" ? rowValue[column.name] : ""; %>
                                  <td><%= cellValue || "—" %></td>
                                <% }) %>
                              </tr>
                            <% }) %>
                          </tbody>
                        </table>
                      </div>
                    <% } else { %>
                      <div class="next-form-value next-form-value-readonly"><%= emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "user-select") { %>
                    <% if (fieldUi.isEditable) { %>
                      <select class="text-input" name="<%= element.name %>">
                        <option value=""><%= emptyValueLabel %></option>
                        <% optionItems.forEach((option) => { %>
                          <option value="<%= option.value %>" <%= currentValueText === option.value ? "selected" : "" %>><%= option.label %></option>
                        <% }) %>
                      </select>
                    <% } else { %>
                      <div class="next-form-value next-form-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "user-multiselect") { %>
                    <% if (fieldUi.isEditable) { %>
                      <div class="next-form-user-multiselect-control" data-user-multiselect-control>
                        <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" data-user-multiselect-input />
                        <select class="text-input next-form-user-multiselect" multiple data-user-multiselect-source>
                          <% optionItems.forEach((option) => { %>
                            <option value="<%= option.value %>" <%= multiSelectedValues.includes(option.value) ? "selected" : "" %>><%= option.label %></option>
                          <% }) %>
                        </select>
                      </div>
                    <% } else { %>
                      <div class="next-form-value next-form-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "radio-group") { %>
                    <% if (fieldUi.isEditable) { %>
                      <div class="next-form-choice-group">
                        <% optionItems.forEach((option) => { %>
                          <label class="next-form-choice">
                            <input type="radio" name="<%= element.name %>" value="<%= option.value %>" <%= currentValueText === option.value ? "checked" : "" %> />
                            <span><%= option.label %></span>
                          </label>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <div class="next-form-value next-form-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "checkbox-group") { %>
                    <% if (fieldUi.isEditable) { %>
                      <div class="next-form-choice-group">
                        <input type="hidden" name="<%= element.name %>" value="<%= currentValueText %>" data-checkbox-group-input />
                        <% optionItems.forEach((option) => { %>
                          <label class="next-form-choice">
                            <input
                              type="checkbox"
                              value="<%= option.value %>"
                              data-checkbox-group-option
                              data-target-input="<%= element.name %>"
                              <%= multiSelectedValues.includes(option.value) ? "checked" : "" %>
                            />
                            <span><%= option.label %></span>
                          </label>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <div class="next-form-value next-form-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "textarea") { %>
                    <% if (fieldUi.isEditable) { %>
                      <textarea class="next-form-runtime-textarea" name="<%= element.name %>" placeholder="<%= emptyValueLabel %>"><%= currentValueText %></textarea>
                    <% } else { %>
                      <textarea class="next-form-runtime-textarea is-readonly" name="<%= element.name %>" placeholder="<%= emptyValueLabel %>" readonly><%= currentValueText %></textarea>
                    <% } %>
                  <% } else if (fieldUi.controlType === "select") { %>
                    <% if (fieldUi.isEditable && optionItems.length > 0) { %>
                      <select class="text-input" name="<%= element.name %>">
                        <option value=""><%= emptyValueLabel %></option>
                        <% optionItems.forEach((option) => { %>
                          <option value="<%= option.value %>" <%= currentValueText === option.value ? "selected" : "" %>><%= option.label %></option>
                        <% }) %>
                      </select>
                    <% } else { %>
                      <div class="next-form-value next-form-value-readonly"><%= displayValue || emptyValueLabel %></div>
                    <% } %>
                  <% } else if (fieldUi.controlType === "date") { %>
                    <input class="text-input <%= fieldUi.isEditable ? "" : "text-input-readonly" %>" type="date" name="<%= element.name %>" value="<%= currentValueText %>" <%= fieldUi.isEditable ? "" : "readonly" %> />
                  <% } else if (fieldUi.controlType === "number") { %>
                    <input class="text-input <%= fieldUi.isEditable ? "" : "text-input-readonly" %>" type="number" step="0.25" min="0" name="<%= element.name %>" value="<%= currentValueText %>" placeholder="<%= emptyValueLabel %>" <%= fieldUi.isEditable ? "" : "readonly" %> />
                  <% } else { %>
                    <input class="text-input <%= fieldUi.isEditable ? "" : "text-input-readonly" %>" type="text" name="<%= element.name %>" value="<%= currentValueText %>" placeholder="<%= orderNumberPlaceholder %>" <%= fieldUi.isEditable ? "" : "readonly" %> />
                  <% } %>
                </article>
              <% } else { %>
                <% if (element.name !== "load_customer" && element.name !== "suggest_material") { %>
                  <article
                    class="field-block next-form-readonly-field next-form-action-card next-form-type-<%= element.controlType %>"
                    data-action-name="<%= element.name %>"
                    data-action-state="<%= actionUi?.isEnabled === false ? "disabled" : "enabled" %>">
                    <div class="next-form-field-head">
                      <label class="field-label"><%= element.label ?? element.name %></label>
                      <span class="chip"><%= element.kind === "action" ? "Action" : "Lookup" %></span>
                    </div>
                    <div class="next-form-action-button" aria-disabled="true"><%= element.label ?? element.name %></div>
                    <div class="next-form-action-meta">
                      <% if (actionUi?.hint) { %>
                        <p><%= actionUi.hint %></p>
                      <% } %>
                      <% if (actionUi?.isEnabled === false) { %>
                        <p>Im aktuellen Status nicht verfuegbar.</p>
                      <% } %>
                    </div>
                  </article>
                <% } %>
              <% } %>
            <% }) %>
          </div>
        <% }) %>

        <% if (section.title === "Kunde" && customerMasterSection) { %>
          <article class="subpanel next-form-masterdata-section" data-masterdata-section="customer">
            <div class="panel-header">
              <h4><%= customerMasterSection.title %></h4>
            </div>
            <div class="next-form-masterdata-grid">
              <% customerMasterSection.entries.forEach((entry) => { %>
                <article class="field-block next-form-readonly-field next-form-masterdata-entry">
                  <label class="field-label"><%= entry.label %></label>
                  <div class="next-form-value next-form-value-readonly"><%= entry.value || entry.emptyValueLabel %></div>
                </article>
              <% }) %>
            </div>
          </article>
        <% } %>

        <% if (section.title === "Leistung" && productMasterSection) { %>
          <article class="subpanel next-form-masterdata-section" data-masterdata-section="product">
            <div class="panel-header">
              <h4><%= productMasterSection.title %></h4>
            </div>
            <div class="next-form-masterdata-grid">
              <% productMasterSection.entries.forEach((entry) => { %>
                <article class="field-block next-form-readonly-field next-form-masterdata-entry">
                  <label class="field-label"><%= entry.label %></label>
                  <div class="next-form-value next-form-value-readonly"><%= entry.value || entry.emptyValueLabel %></div>
                </article>
              <% }) %>
            </div>
          </article>
        <% } %>

        <% if (section.title === "Leistung" && productionBatchReference) { %>
          <article class="subpanel next-form-masterdata-section" data-form-reference-section="production_batch">
            <div class="panel-header">
              <h4><%= productionBatchReference.title %></h4>
            </div>
            <p class="field-help">Quelle: <strong><%= productionBatchReference.sourceLabel %></strong> · <a class="text-link" href="<%= productionBatchReference.href %>">Dokument öffnen</a></p>
            <div class="next-form-masterdata-grid">
              <% productionBatchReference.entries.forEach((entry) => { %>
                <article class="field-block next-form-readonly-field next-form-masterdata-entry">
                  <label class="field-label"><%= entry.label %></label>
                  <div class="next-form-value next-form-value-readonly"><%= entry.value || entry.emptyValueLabel %></div>
                </article>
              <% }) %>
            </div>
          </article>
        <% } %>
      </article>
    <% }) %>
  </div>
<% } %>
