<details class="panel panel-collapsible">
  <summary class="collapsible-summary">
    <div class="collapsible-summary-copy">
      <strong>Verlauf</strong>
      <% if (latestAuditEvent) { %>
        <% const latestActor = users.find((entry) => entry.id === latestAuditEvent.actorUserId); %>
        <span><%= latestAuditEvent.eventType %> · <%= latestActor?.displayName ?? "System" %> · <%= latestAuditEvent.createdAt %></span>
      <% } else { %>
        <span>Keine Eintraege.</span>
      <% } %>
    </div>
    <div class="collapsible-summary-meta">
      <span><%= documentDetail.auditEvents.length %></span>
    </div>
  </summary>
  <div class="collapsible-body">
    <% if (documentDetail.auditEvents.length === 0) { %>
      <p>Keine Eintraege.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Aktion</th>
              <th>Von</th>
              <th>Zeitpunkt</th>
            </tr>
          </thead>
          <tbody>
            <% documentDetail.auditEvents.forEach((event) => { %>
              <% const actor = users.find((entry) => entry.id === event.actorUserId); %>
              <tr>
                <td>
                  <strong><%= event.eventType %></strong>
                  <% if (event.message) { %>
                    <div class="table-meta"><%= event.message %></div>
                  <% } %>
                </td>
                <td><%= actor?.displayName ?? "System" %></td>
                <td><%= event.createdAt %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</details>
