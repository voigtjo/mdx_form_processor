<% if (documentDetail.formRuntimeReference) { %>
  <details class="panel panel-collapsible page-header-collapsible">
    <summary class="collapsible-summary">
      <div class="collapsible-summary-copy">
        <strong><%= documentDetail.document.title %></strong>
        <span><%= documentDetail.document.templateName %> v<%= documentDetail.document.templateVersion %> · <%= documentDetail.document.formType %> · <%= documentDetail.document.status %></span>
      </div>
      <div class="collapsible-summary-meta">
        <span>Document</span>
        <span><%= documentDetail.document.status %></span>
      </div>
    </summary>
    <div class="collapsible-body">
      <span class="eyebrow">Document</span>
      <h2><%= documentDetail.document.title %></h2>
      <p class="hero-inline-meta"><strong>Formular:</strong> <%= documentDetail.document.templateName %> v<%= documentDetail.document.templateVersion %> · <strong>Typ:</strong> <%= documentDetail.document.formType %> · <strong>Workflow:</strong> <%= documentDetail.document.workflowTemplateName %> v<%= documentDetail.document.workflowTemplateVersion %></p>
      <p class="hero-inline-meta"><strong>Status:</strong> <%= documentDetail.document.status %> · <strong><%= nextStepLabel %></strong><% if (activeAssignments.length > 0) { %> · <strong>Assignments:</strong> <%= activeAssignments.length %> aktiv<%= assignmentSummary ? " · " + assignmentSummary : "" %><% } %> · <%= documentDetail.document.updatedAt %></p>
      <div class="workflow-track workflow-track-header">
        <% workflowStepsForHeader.forEach((step) => { %>
          <span class="workflow-step <%= documentDetail.document.status === step ? "is-active" : "" %>"><%= step %></span>
        <% }) %>
        <% if (!workflowStepsForHeader.includes(documentDetail.document.status)) { %>
          <span class="workflow-step is-active"><%= documentDetail.document.status %></span>
        <% } %>
      </div>
      <div class="hero-actions">
        <a class="text-link" href="/documents?user=<%= activeUser.key %>">Back to Documents</a>
      </div>
    </div>
  </details>
<% } else { %>
  <section class="hero-card">
    <div>
      <h2><%= documentDetail.document.title %></h2>
      <p><%= documentDetail.document.templateName %> · <%= documentDetail.document.formType %></p>
    </div>
    <div class="hero-metrics">
      <article>
        <strong><%= documentDetail.document.status %></strong>
        <span>Status</span>
      </article>
      <article>
        <strong>v<%= documentDetail.document.templateVersion %></strong>
        <span>Template</span>
      </article>
      <article>
        <strong>v<%= documentDetail.document.workflowTemplateVersion %></strong>
        <span>Workflow</span>
      </article>
    </div>
  </section>
<% } %>
