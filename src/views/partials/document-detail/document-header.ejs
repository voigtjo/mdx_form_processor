<% if (documentDetail.nextFormReference) { %>
  <section class="hero-card hero-card-compact">
    <div>
      <span class="eyebrow">Document</span>
      <h2><%= documentDetail.document.title %></h2>
      <p class="hero-inline-meta"><strong>Dokument:</strong> <%= documentDetail.document.title %> · <strong>Formular:</strong> <%= documentDetail.document.templateName %> v<%= documentDetail.document.templateVersion %> · <strong>Workflow:</strong> <%= documentDetail.document.workflowTemplateName %> v<%= documentDetail.document.workflowTemplateVersion %></p>
      <p class="hero-inline-meta"><strong>Status:</strong> <%= documentDetail.document.status %> · <strong>Assignments:</strong> <%= activeAssignments.length %> aktiv<%= assignmentSummary ? " · " + assignmentSummary : "" %> · <strong><%= nextStepLabel %></strong></p>
      <p class="hero-inline-meta">Gestartet aus Formular v<%= documentDetail.document.templateVersion %> und Workflow v<%= documentDetail.document.workflowTemplateVersion %> · Updated <%= documentDetail.document.updatedAt %> · Created <%= documentDetail.document.createdAt %></p>
    </div>
    <div class="workflow-track workflow-track-header">
      <% workflowStepsForHeader.forEach((step) => { %>
        <span class="workflow-step <%= documentDetail.document.status === step ? "is-active" : "" %>"><%= step %></span>
      <% }) %>
      <% if (!workflowStepsForHeader.includes(documentDetail.document.status)) { %>
        <span class="workflow-step is-active"><%= documentDetail.document.status %></span>
      <% } %>
    </div>
    <div class="hero-actions">
      <a class="text-link" href="/documents?user=<%= activeUser.key %>">Back to Documents</a>
    </div>
  </section>
<% } else { %>
  <section class="hero-card">
    <div>
      <span class="eyebrow">Arbeits-UI</span>
      <h2><%= documentDetail.document.title %></h2>
      <p>Detailsicht fuer ein einzelnes Dokument mit erstem Save-Schnitt fuer einfache Formwerte.</p>
    </div>
    <div class="hero-metrics">
      <article>
        <strong><%= documentDetail.document.status %></strong>
        <span>Status</span>
      </article>
      <article>
        <strong>v<%= documentDetail.document.templateVersion %></strong>
        <span>Template</span>
      </article>
      <article>
        <strong>v<%= documentDetail.document.workflowTemplateVersion %></strong>
        <span>Workflow</span>
      </article>
    </div>
  </section>
<% } %>
