<section class="panel panel-primary-slice">
  <div class="panel-header">
    <h3><%= documentDetail.document.templateKey === "service-report" ? "Service-Report" : documentDetail.document.formType === "customer_order" ? "Kundenservice-Dokumentation" : "Formular" %></h3>
  </div>

  <form
    class="form-stack"
    method="post"
    action="/documents/<%= documentDetail.document.id %>/form?user=<%= activeUser.key %>"
    data-document-form="true"
    data-document-id="<%= documentDetail.document.id %>"
  >
    <% const activeApproverNames = documentDetail.assignments
      .filter((assignment) => assignment.active && assignment.role === "approver")
      .map((assignment) => users.find((entry) => entry.id === assignment.userId)?.displayName ?? assignment.userId); %>
    <div id="document-workflow-zone-fragment" data-fragment="document-workflow-zone">
      <% if (typeof workflowZoneHtml === "string") { %>
        <%- workflowZoneHtml %>
      <% } else { %>
        <%- include("form-runtime-workflow-zone", {
          documentDetail,
          activeUser,
          formRuntimeStatus,
          formRuntimeError,
          assignStatus,
          assignError,
          submitStatus,
          submitError,
          approveStatus,
          approveError,
          rejectStatus,
          rejectError,
          reassignStatus,
          reassignError,
          archiveStatus,
          archiveError,
          activeApproverNames
        }) %>
      <% } %>
    </div>
    <div id="document-form-body-fragment" data-fragment="document-form-body">
      <% if (typeof formBodyHtml === "string") { %>
        <%- formBodyHtml %>
      <% } else { %>
        <%- include("form-runtime-form-body", {
          documentDetail,
          activeUser
        }) %>
      <% } %>
    </div>
  </form>
</section>
