<% if (nextFormStatus) { %>
  <div class="notice-card notice-success">
    <strong>Formular aktualisiert</strong>
    <p><%= nextFormStatus %></p>
  </div>
<% } %>

<% if (nextFormError) { %>
  <div class="notice-card notice-error">
    <strong>Aktion nicht moeglich</strong>
    <p><%= nextFormError %></p>
  </div>
<% } %>

<% if (submitStatus) { %>
  <div class="notice-card notice-success">
    <strong>Submit erfolgreich</strong>
    <p><%= submitStatus %></p>
  </div>
<% } %>

<% if (submitError) { %>
  <div class="notice-card notice-error">
    <strong>Submit nicht moeglich</strong>
    <p><%= submitError %></p>
  </div>
<% } %>

<% if (approveStatus) { %>
  <div class="notice-card notice-success">
    <strong>Approve erfolgreich</strong>
    <p><%= approveStatus %></p>
  </div>
<% } %>

<% if (approveError) { %>
  <div class="notice-card notice-error">
    <strong>Approve nicht moeglich</strong>
    <p><%= approveError %></p>
  </div>
<% } %>

<% if (rejectStatus) { %>
  <div class="notice-card notice-success">
    <strong>Reject erfolgreich</strong>
    <p><%= rejectStatus %></p>
  </div>
<% } %>

<% if (rejectError) { %>
  <div class="notice-card notice-error">
    <strong>Reject nicht moeglich</strong>
    <p><%= rejectError %></p>
  </div>
<% } %>

<% if (archiveStatus) { %>
  <div class="notice-card notice-success">
    <strong>Archive erfolgreich</strong>
    <p><%= archiveStatus %></p>
  </div>
<% } %>

<% if (archiveError) { %>
  <div class="notice-card notice-error">
    <strong>Archive nicht moeglich</strong>
    <p><%= archiveError %></p>
  </div>
<% } %>

<% const nextFormEditState = documentDetail.nextFormReference?.editState ?? documentDetail.editState; %>

<div class="next-form-toolbar">
  <div class="workflow-action-strip">
    <button
      type="submit"
      class="button-primary"
      name="intent"
      value="save-next-form"
      hx-post="/documents/<%= documentDetail.document.id %>/next-form?user=<%= activeUser.key %>"
      hx-target="#document-workspace-fragment"
      hx-swap="outerHTML show:none"
      <%= nextFormEditState.isAvailable ? "" : "disabled" %>
    >Werte speichern</button>
    <% if (documentDetail.submitState.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/submit?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/submit?user=<%= activeUser.key %>"
        hx-target="#document-workspace-fragment"
        hx-swap="outerHTML show:none"
      >Submit</button>
    <% } else if (documentDetail.document.status === "created") { %>
      <button class="button-secondary" type="button" disabled>Submit</button>
    <% } %>
    <% if (documentDetail.approveState.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/approve?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/approve?user=<%= activeUser.key %>"
        hx-target="#document-workspace-fragment"
        hx-swap="outerHTML show:none"
      >Approve</button>
    <% } %>
    <% if (documentDetail.rejectState.isAvailable) { %>
      <button
        class="button-secondary"
        type="submit"
        formaction="/documents/<%= documentDetail.document.id %>/reject?user=<%= activeUser.key %>"
        hx-post="/documents/<%= documentDetail.document.id %>/reject?user=<%= activeUser.key %>"
        hx-target="#document-workspace-fragment"
        hx-swap="outerHTML show:none"
      >Reject</button>
    <% } %>
  </div>
  <% if (!nextFormEditState.isAvailable) { %>
    <p class="field-help">Formular aktuell read-only. <%= nextFormEditState.reason ?? "Bearbeitung ist im aktuellen Status nicht verfuegbar." %></p>
  <% } %>
  <% if (!documentDetail.submitState.isAvailable && documentDetail.document.status === "created") { %>
    <p class="field-help">Fuer Submit fehlen noch Angaben. <%= documentDetail.submitState.reason ?? "Pflichtfelder oder Berechtigungen fehlen." %></p>
  <% } %>
  <% if (!documentDetail.submitState.isAvailable && !documentDetail.approveState.isAvailable && !documentDetail.rejectState.isAvailable && documentDetail.document.status === "submitted" && activeApproverNames.length > 0) { %>
    <p class="field-help">Freigabe liegt bei <strong><%= activeApproverNames.join(", ") %></strong>.</p>
  <% } %>
</div>
