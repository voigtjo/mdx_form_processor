<header class="topbar">
  <div class="brand-block">
    <span class="eyebrow">Handwerker App</span>
    <h1><%= appName %></h1>
    <p>Serviceeinsaetze, Produktion und Nachweise</p>
  </div>

  <div class="user-select">
    <label for="user-switcher">Aktiver User</label>
    <select id="user-switcher" data-user-switcher>
      <% users.forEach((user) => { %>
        <option value="<%= user.key %>" <%= user.key === activeUser.key ? "selected" : "" %>>
          <%= user.displayName %>
        </option>
      <% }) %>
    </select>
  </div>
</header>

<nav class="main-nav" aria-label="Hauptnavigation">
  <% navigation.forEach((item) => { %>
    <a href="<%= item.href %>" class="nav-link <%= item.isActive ? "is-active" : "" %>">
      <%= item.label %>
    </a>
  <% }) %>
</nav>
