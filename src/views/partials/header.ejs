<header class="topbar">
  <div class="brand-block">
    <span class="eyebrow">Handwerker App</span>
    <h1><%= appName %></h1>
    <p><%= t("app.tagline") %></p>
  </div>

  <form class="user-select" method="get" action="">
    <label for="user-switcher"><%= t("header.activeUser") %></label>
    <select id="user-switcher" name="user" data-user-switcher onchange="this.form.requestSubmit()">
      <% users.forEach((user) => { %>
        <option value="<%= user.key %>" <%= user.key === activeUser.key ? "selected" : "" %>>
          <%= user.displayName %>
        </option>
      <% }) %>
    </select>
  </form>
</header>

<nav class="main-nav" aria-label="Hauptnavigation">
  <% navigation.forEach((item) => { %>
    <a href="<%= item.href %>" class="nav-link <%= item.isActive ? "is-active" : "" %>">
      <%= item.label %>
    </a>
  <% }) %>
</nav>
