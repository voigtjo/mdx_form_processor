<!DOCTYPE html>
<html lang="<%= locale %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | <%= appName %></title>
    <link rel="stylesheet" href="/public/css/app.css" />
    <script defer src="/public/vendor/htmx/htmx.min.js"></script>
    <script type="module" src="/public/js/code-editor.js"></script>
    <script defer src="/public/js/app.js"></script>
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <div class="brand-block">
          <span class="eyebrow">Handwerker App</span>
          <h1><%= appName %></h1>
          <p><%= t("app.tagline") %></p>
        </div>

        <div class="user-select">
          <label for="user-switcher"><%= t("header.activeUser") %></label>
          <select id="user-switcher" name="user" data-context-switcher data-context-param="user">
            <% users.forEach((user) => { %>
              <option value="<%= user.key %>" <%= user.key === activeUser.key ? "selected" : "" %>>
                <%= user.displayName %>
              </option>
            <% }) %>
          </select>
          <label for="group-switcher"><%= t("header.activeGroup") %></label>
          <select id="group-switcher" name="group" data-context-switcher data-context-param="group">
            <option value="__all__" <%= !selectedGroup ? "selected" : "" %>><%= t("header.allGroups") %></option>
            <% availableGroups.forEach((group) => { %>
              <option value="<%= group.key %>" <%= selectedGroup?.id === group.id ? "selected" : "" %>>
                <%= group.name %>
              </option>
            <% }) %>
          </select>
        </div>
      </header>

      <nav class="main-nav" aria-label="Hauptnavigation">
        <% navigation.forEach((item) => { %>
          <a href="<%= item.href %>" class="nav-link <%= item.isActive ? "is-active" : "" %>">
            <%= item.label %>
          </a>
        <% }) %>
      </nav>

      <main class="page-shell">
        <%- body %>
      </main>
    </div>

    <% if (typeof appDialog !== "undefined" && appDialog) { %>
      <div class="dialog-backdrop" data-app-dialog>
        <div class="dialog-card dialog-<%= appDialog.type %>" role="dialog" aria-modal="true" aria-labelledby="app-dialog-title">
          <div class="dialog-header">
            <h2 id="app-dialog-title"><%= appDialog.title %></h2>
            <a
              class="dialog-close"
              href="<%= appDialog.closeHref %>"
              aria-label="Dialog schliessen"
            >Schliessen</a>
          </div>
          <p><%= appDialog.message %></p>
        </div>
      </div>
    <% } %>
  </body>
  </html>
