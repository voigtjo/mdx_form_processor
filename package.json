    "fastify": "^5.0.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
