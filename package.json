{
  "name": "mdx_form_processor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Greenfield MVP foundation for the MDX form and workflow processor.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
